  <script>
    /* pre-paint (boot-ground): name + the visitor's layout code land BEFORE the module, so a
       glitter page NEVER flashes default first. Decode + the same fail-closed CSS refusal —
       no trust decisions beyond "is this lawful CSS"; the module re-derives κ and owns behaviour. */
    (function () {
      try {
        var m = location.hash.match(/#p=v[23]\.([A-Za-z0-9_-]+)/);
        var p = m ? JSON.parse(atob(m[1].replace(/-/g, "+").replace(/_/g, "/").padEnd(Math.ceil(m[1].length / 4) * 4, "="))) : null;
        if (p && p.kind === "profile") {
          document.getElementById("name").textContent = p.name || "";
          var css = String(p.customCss || "");
          if (css && css.length <= 32768 && !/[<]|@import|expression\s*\(|behavior\s*:|javascript\s*:|url\(\s*['"]?\s*(?!data:|https:)[a-z]/i.test(css))
            document.getElementById("usercss").textContent = css;
        }
      } catch (e) { /* refused → default skin */ }
    })();
  </script>

  <script type="module">
    import * as YS from "./holo-yourspace.mjs";

    const OS = "https://hologram-technologies.github.io/Q";
    const $ = (id) => document.getElementById(id);
    const esc = (s) => String(s || "").replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]));
    const ME_KEY = "holo-yourspace.me.v2";               // key stable across versions; payload self-describes
    const EMOJIS = ["🙂","😎","🛰️","🪐","🌸","🔥","🌊","🌙","⚡","🎧","🎮","🐉","🦋","🌵","👾","✨"];
    const SITE = OS + "/apps/yourspace/";                // canonical public home of this app

    /* ── Two guest skins, MySpace anatomy kept, restyled to feel like home. Pure CSS, zero
       external hosts, fail-closed-clean (no <, no @import, no scripts). ─────────────────── */
    const SKIN_OPENAI =
      ":root{--ms-blue:#000;--ms-band:#000;--ms-label:#f2f2f3;--ms-cell:#fafafa;--ms-labeltext:#0d0d0d;" +
      "--ms-orange:#10a37f;--ms-orangeband:#eef8f4;--ms-cth:#10a37f;--ms-ctd:#f7faf9;--ms-red:#10a37f;--ms-page:#fff;--ms-bg:#ececec}" +
      "body{background:#ececec}a{color:#10a37f}a:hover{color:#0a7f63}.mainhead h2,.blurbs h3{color:#10a37f}.comments th{color:#fff}";
    const SKIN_GEFORCE =
      ":root{--ms-blue:#76b900;--ms-band:#111;--ms-label:#141414;--ms-cell:#0d0d0d;--ms-labeltext:#76b900;" +
      "--ms-orange:#76b900;--ms-orangeband:#0f1a00;--ms-cth:#1a2a00;--ms-ctd:#0d0d0d;--ms-red:#9fe000;--ms-page:#0b0b0b;--ms-bg:#000}" +
