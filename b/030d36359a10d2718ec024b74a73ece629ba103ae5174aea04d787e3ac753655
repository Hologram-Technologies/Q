<!doctype html>
<meta charset="utf-8">
<title>Holo Onion — arti-in-wasm first light (C3)</title>
<style>
  body { background:#0d1117; color:#c9d1d9; font:14px/1.6 ui-monospace,Menlo,monospace; margin:0; padding:32px; }
  h1 { font-size:17px; color:#a5b4fc; margin:0 0 4px; }
  .sub { color:#6e7681; margin:0 0 20px; }
  #log div { padding:2px 0; } .ok{color:#3fb950} .bad{color:#f85149} .info{color:#8b949e}
  #state { margin-top:16px; font-weight:600; padding:10px 14px; border-radius:8px; display:inline-block; }
  .green{background:#12261a;color:#3fb950;border:1px solid #238636} .red{background:#2a1416;color:#f85149;border:1px solid #da3633} .warn{background:#2b2416;color:#d29922;border:1px solid #9e6a03}
</style>
<h1>Holo Onion · arti-in-wasm — first light</h1>
<p class="sub">Loads the 9.4 MB arti Tor client (wasm) in this browser, then drives it over the live B1 Snowflake stream. C3.</p>
<div id="log"></div>
<div id="state"></div>
<script type="module">
import init, { run_tor, c2_assert_runtime } from "./arti-pkg/holo_arti_rt.js";
import { connectSnowflake } from "./holo-onion-snowflake-connect.mjs";

const logEl = document.getElementById("log");
const line = (c,m)=>{const d=document.createElement("div");d.className=c;d.textContent=`[${(performance.now()/1000).toFixed(1)}s] ${m}`;logEl.appendChild(d);};
const setState=(c,m)=>{const s=document.getElementById("state");s.className=c;s.textContent=m;};
window.__HOLO_ARTI__ = { stage:"start", initOk:false, ran:false, error:null };

(async () => {
  // 1. instantiate the arti wasm
  try {
    line("info","instantiating arti wasm (9.4 MB)…");
    await init();
    line("ok","✓ arti wasm instantiated in this browser");
    line("ok","✓ "+c2_assert_runtime());
    window.__HOLO_ARTI__.initOk = true;
    setState("warn","arti loaded — opening B1 Snowflake stream…");
  } catch (e) {
    line("bad","init failed: "+e.message);
    window.__HOLO_ARTI__.error = "init: "+e.message;
    setState("red","arti wasm failed to instantiate");
    return;
  }
  // 2. open the live B1 stream and hand it to arti
  let conn;
  try {
    conn = await connectSnowflake({ log:(m)=>line("info","  "+m), gatherTimeoutMs:4000, openTimeoutMs:25000 });
    line("ok","✓ B1 DataChannel open — driving arti bootstrap over it (heavy; may stall on consensus)");
    setState("warn","arti bootstrapping over Tor…");
    window.__HOLO_ARTI__.stage = "bootstrapping";
    const res = await run_tor(conn.stream);   // instantiates TorClient + bootstrap() over the B1 stream
    line("ok","✓ run_tor returned: "+res);
    window.__HOLO_ARTI__ = {...window.__HOLO_ARTI__, ran:true, result:String(res)};
    setState("green","GREEN — arti bootstrapped in-browser over Snowflake");
  } catch (e) {
    line("bad","run_tor error: "+(e && e.message || e));
    window.__HOLO_ARTI__ = {...window.__HOLO_ARTI__, ran:true, error:String(e && e.message || e)};
    setState("warn","arti loaded + ran; bootstrap did not complete (see log) — expected until dir-store/consensus (C4) is done");
    try { conn && conn.close(); } catch {}
  }
})();
</script>
