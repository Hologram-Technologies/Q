<!doctype html>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<title>Holo Games</title>
<!--
  Holo Games — the full library on the live static /Q. Two tiers, one grid:
    · Plays Instantly — freely-shared homebrew, same-origin ROMs, zero infra (CORS, no proxy).
    · Every system    — the No-Intro library (thousands per system) browsed from shipped name
                        shards + libretro-thumbnails art (GitHub, CORS); a tap streams the ROM
                        through the operator's ROM proxy (a Cloudflare Worker — set once below),
                        κ-verified and cached locally after first play.
  Cores + WebGPU projector run on-device (play.html). No game server anywhere.
-->
<style>
  :root{color-scheme:dark;--bg:#07080b;--panel:#0f1218;--line:#1a1e26;--text:#e8ecf4;--muted:#8b93a7;--accent:#6c8cff;--gb:#9bbc0f}
  *{box-sizing:border-box}
  html,body{margin:0;height:100%;background:radial-gradient(120% 80% at 50% -10%,#14171f 0%,#0a0c10 55%,var(--bg) 100%);color:var(--text);font:15px/1.5 Inter,system-ui,-apple-system,"Segoe UI",sans-serif;-webkit-font-smoothing:antialiased}
  header{display:flex;align-items:center;gap:14px;padding:22px clamp(16px,4vw,44px) 6px}
  .mark{width:32px;height:32px;border-radius:9px;background:linear-gradient(140deg,var(--accent),#9bbcff);display:grid;place-items:center;font-size:17px;box-shadow:0 6px 18px #6c8cff44}
  h1{font-size:clamp(20px,3vw,28px);font-weight:750;letter-spacing:-.02em;margin:0}
  .spacer{flex:1}
  .cfg{font-size:12.5px;color:var(--muted);border:1px solid var(--line);background:#ffffff0a;border-radius:10px;padding:8px 12px;cursor:pointer}
  .cfg.on{color:#bcd35a;border-color:#9bbc0f55}
  #search{width:100%;max-width:460px;margin:8px clamp(16px,4vw,44px);background:#ffffff0a;border:1px solid var(--line);border-radius:12px;color:inherit;font:inherit;padding:10px 15px;outline:none}
  #search:focus{border-color:var(--accent)}
  .sys{display:flex;gap:8px;padding:6px clamp(16px,4vw,44px) 12px;overflow-x:auto;scrollbar-width:none}
  .sys::-webkit-scrollbar{display:none}
  .chip{flex:none;font:600 13px/1 inherit;padding:9px 15px;border-radius:999px;cursor:pointer;background:#ffffff0a;border:1px solid #ffffff12;color:#aab3c5;transition:all .15s;white-space:nowrap}
  .chip:hover{color:var(--text);border-color:#ffffff2a}
  .chip.on{background:color-mix(in srgb,var(--accent) 20%,transparent);border-color:var(--accent);color:#dfe7ff}
  #note{padding:0 clamp(16px,4vw,44px);color:var(--muted);font-size:12.5px;min-height:16px}
  #grid{display:grid;gap:20px 15px;padding:12px clamp(16px,4vw,44px) 60px;grid-template-columns:repeat(auto-fill,minmax(140px,1fr))}
  .tile{cursor:pointer;border:0;background:none;padding:0;text-align:left;font:inherit;color:inherit;outline:none}
  .box{position:relative;aspect-ratio:.72;border-radius:12px;overflow:hidden;background:linear-gradient(158deg,#1a2030,#0d1016);border:1px solid var(--line);display:grid;place-items:center;box-shadow:0 14px 30px -16px #000c;transition:transform .2s cubic-bezier(.2,.7,.2,1),box-shadow .2s,border-color .2s}
  .box img{width:100%;height:100%;object-fit:contain;opacity:0;transition:opacity .35s}
  .box img.in{opacity:1}
  .box .ph{font-weight:800;font-size:24px;color:#2b3a0a;width:54%;aspect-ratio:1;border-radius:13px;display:grid;place-items:center;background:radial-gradient(120% 120% at 30% 20%,#b6d84a,var(--gb) 60%,#7a9c0c)}
  .tile:hover .box,.tile:focus-visible .box{transform:translateY(-5px) scale(1.05);border-color:var(--accent);box-shadow:0 24px 44px -16px #000e,0 0 0 2px var(--accent)}
  .badge{position:absolute;top:7px;left:7px;font:700 9px/1 inherit;padding:4px 7px;border-radius:6px;background:#9bbc0fdd;color:#1a2a05}
  .nm{margin-top:8px;font-weight:650;font-size:13px;line-height:1.3;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
  #more{height:2px}
  #stage{position:fixed;inset:0;z-index:50;display:none;background:#000}
  #stage.on{display:block}
  #stage iframe{position:absolute;inset:0;width:100%;height:100%;border:0}
  #stage .x{position:absolute;top:16px;right:20px;z-index:2;width:40px;height:40px;border-radius:50%;border:1px solid #ffffff22;background:#000000aa;color:#fff;font-size:16px;cursor:pointer;opacity:0;transition:opacity .25s}
  #stage:hover .x,#stage .x:focus-visible{opacity:1}
  #dlg{position:fixed;inset:0;z-index:60;display:none;background:#000a;backdrop-filter:blur(6px)}
  #dlg.on{display:grid;place-items:center}
  .card{background:var(--panel);border:1px solid var(--line);border-radius:16px;padding:24px;width:min(92vw,480px);box-shadow:0 40px 100px #000c}
  .card h2{margin:0 0 6px;font-size:18px}
  .card p{color:var(--muted);font-size:13px;margin:0 0 14px}
  .card input{width:100%;background:#0c0e16;border:1px solid var(--line);border-radius:10px;color:inherit;font:inherit;padding:11px 13px;outline:none}
  .card input:focus{border-color:var(--accent)}
  .card .row{display:flex;gap:10px;margin-top:14px;justify-content:flex-end}
  .card button{font:inherit;padding:10px 18px;border-radius:10px;border:1px solid var(--line);background:#ffffff0d;color:var(--text);cursor:pointer}
  .card button.primary{background:linear-gradient(180deg,var(--accent),#4f6fe0);border:0;font-weight:650}
</style>

<header>
  <div class="mark">🎮</div>
  <h1>Holo Games</h1>
  <div class="spacer"></div>
  <button class="cfg" id="cfg">⚙ ROM proxy</button>
</header>
<input id="search" type="search" placeholder="Search this system…" autocomplete="off">
<div class="sys" id="sys"></div>
<div id="note"></div>
<div id="grid"></div>
<div id="more"></div>

<div id="stage"><iframe allow="autoplay; fullscreen; gamepad"></iframe><button class="x" title="Back (Esc)">✕</button></div>

<div id="dlg"><div class="card">
  <h2>Connect your ROM proxy</h2>
  <p>The freely-shared homebrew (★) plays with no setup. To stream the full commercial library, paste your Cloudflare Worker URL (see <code>_dev/rom-proxy-worker.js</code>). Stored only in this browser. Games κ-cache locally after first play.</p>
  <input id="proxy" type="url" placeholder="https://holo-rom-proxy.you.workers.dev" autocomplete="off">
  <div class="row"><button id="dlg-clear">Clear</button><button class="primary" id="dlg-save">Save</button></div>
</div></div>

<script type="module">
import { search as searchLib, streamTitle } from "./holo-stream.mjs";

// popular systems — code · label · No-Intro sys (play.html?sys=) · index shards · thumbnails repo
const SYS = [
  ["arcade","★ Plays Instantly","Nintendo - Game Boy",[],""],
  ["gb","Game Boy","Nintendo - Game Boy",["theentiregameboycollection"],"Nintendo_-_Game_Boy"],
  ["gbc","Game Boy Color","Nintendo - Game Boy Color",["theentireGAMEBOYCOLORcollection"],"Nintendo_-_Game_Boy_Color"],
  ["nes","NES","Nintendo - Nintendo Entertainment System",["No-Intro_NES"],"Nintendo_-_Nintendo_Entertainment_System"],
  ["snes","SNES","Nintendo - Super Nintendo Entertainment System",["No-Intro_Super_Nintendo_SNES"],"Nintendo_-_Super_Nintendo_Entertainment_System"],
  ["gba","GBA","Nintendo - Game Boy Advance",["ef_gba_no-intro_2024-02-21"],"Nintendo_-_Game_Boy_Advance"],
  ["gen","Genesis","Sega - Mega Drive - Genesis",["ef_mega_genesis_no-intro_2024-04-21"],"Sega_-_Mega_Drive_-_Genesis"],
  ["sms","Master System","Sega - Master System - Mark III",["master-system-no-intro-romset-2025-06-06"],"Sega_-_Master_System_-_Mark_III"],
  ["gg","Game Gear","Sega - Game Gear",["game-gear-no-intro-romset-2025-07-29"],"Sega_-_Game_Gear"],
];
const WINDOW = 48, RAW = "https://raw.githubusercontent.com/libretro-thumbnails/";
const $ = (id) => document.getElementById(id);
const plain = (n) => n.split("/").pop().replace(/\s*\([^)]*\)/g,"").trim();
const region = (n) => { const r=(/\(([^)]*)\)/.exec(n)||[,""])[1].toLowerCase(); return r.includes("usa")?0:r.includes("world")?1:r.includes("europe")?2:3; };
// operator's ROM proxy (Cloudflare Worker) is the default so the whole library plays out of the
// box; a user can override it in ⚙ (stored per-browser). See _dev/rom-proxy-worker.js.
const DEFAULT_PROXY = "https://holo-rom-proxy.trinity-03d.workers.dev";
let proxy = localStorage.getItem("holo-rom-proxy") || DEFAULT_PROXY;
globalThis.HOLO_ROM_PROXY = proxy || undefined;

// ── ROM-proxy settings ──
$("cfg").classList.toggle("on", !!proxy);
$("cfg").onclick = () => { $("proxy").value = proxy; $("dlg").classList.add("on"); $("proxy").focus(); };
$("dlg-save").onclick = () => { proxy = $("proxy").value.trim().replace(/\/$/,""); localStorage.setItem("holo-rom-proxy", proxy); globalThis.HOLO_ROM_PROXY = proxy || undefined; $("cfg").classList.toggle("on", !!proxy); $("dlg").classList.remove("on"); render(); };
$("dlg-clear").onclick = () => { $("proxy").value = ""; };
$("dlg").onclick = (e) => { if (e.target === $("dlg")) $("dlg").classList.remove("on"); };

// ── play overlay ──
const stage = $("stage"), frame = stage.querySelector("iframe");
const closeStage = () => { stage.classList.remove("on"); frame.src = "about:blank"; };
stage.querySelector(".x").onclick = closeStage;
addEventListener("keydown",(e)=>{ if(e.key==="Escape"&&stage.classList.contains("on")){e.preventDefault();closeStage();} });
const play = (url) => { frame.src = url; stage.classList.add("on"); };

// ── data ──
let arcade = [];
try { arcade = (await (await fetch("./arcade.json")).json()).games || []; } catch(e){}
const shardCache = {};
async function names(code){
  if (shardCache[code]) return shardCache[code];
  const items = (SYS.find(s=>s[0]===code)||[])[3] || [];
  const all = [];
  for (const it of items){ try { all.push(...await (await fetch("./index/"+it+".json")).json()); } catch(e){} }
  // one entry per plain title, prefer USA/World
  const seen = new Map();
  for (const n of all){ const k=plain(n).toLowerCase(); const p=seen.get(k); if(!p||region(n)<region(p)) seen.set(k,n); }
  return shardCache[code] = [...seen.values()];
}

// ── render (windowed, lazy GitHub art) ──
let cur = "arcade", view = [], shown = 0, io;
function artUrl(code, name){ const repo=(SYS.find(s=>s[0]===code)||[])[4]; return repo? RAW+repo+"/master/Named_Boxarts/"+encodeURIComponent(name.split("/").pop())+".png" : ""; }
function tile(entry){
  const b=document.createElement("button"); b.className="tile";
  const initial=(entry.t||"?").replace(/[^A-Za-z0-9]/,"").charAt(0).toUpperCase()||"▸";
  b.innerHTML=`<div class="box">${entry.arcade?'<span class="badge">★ PLAYS NOW</span>':''}<div class="ph">${initial}</div><img alt="" decoding="async"></div><div class="nm"></div>`;
  b.querySelector(".nm").textContent=entry.t;
  const img=b.querySelector("img");
  if(entry.art){ img.dataset.src=entry.art; io.observe(b); }
  b.onclick=entry.go;
  return b;
}
function appendWindow(){
  const grid=$("grid"), more=$("more"), frag=document.createDocumentFragment();
  const end=Math.min(shown+WINDOW,view.length);
  for(let i=shown;i<end;i++) frag.appendChild(tile(view[i]));
  shown=end; grid.insertBefore(frag,more);
}
async function render(){
  $("sys").querySelectorAll(".chip").forEach(c=>c.classList.toggle("on",c.dataset.code===cur));
  const q=$("search").value.trim().toLowerCase();
  const sysDef=SYS.find(s=>s[0]===cur), playSys=sysDef[2];
  if(cur==="arcade"){
    view=arcade.filter(g=>!q||g.title.toLowerCase().includes(q)).map(g=>({t:g.title,art:"",arcade:true,
      go:()=>play("play.html?rom="+encodeURIComponent(g.rom)+"&sys="+encodeURIComponent("Nintendo - Game Boy")+"&title="+encodeURIComponent(g.title))}));
    $("note").textContent = view.length+" freely-shared games — play instantly, no setup.";
  } else {
    const list=await names(cur);
    const f=q?list.filter(n=>plain(n).toLowerCase().includes(q)):list;
    view=f.map(n=>{ const t=plain(n); return {t,art:artUrl(cur,n),
      go:()=>{ if(!globalThis.HOLO_ROM_PROXY){ $("proxy").value=proxy; $("dlg").classList.add("on"); return; }
        play("play.html?title="+encodeURIComponent(t)+"&sys="+encodeURIComponent(playSys)); }};});
    $("note").textContent = list.length.toLocaleString()+" games · "+(globalThis.HOLO_ROM_PROXY?"tap to stream & play":"tap sets up the ROM proxy first");
  }
  const grid=$("grid"); grid.textContent=""; const more=document.createElement("div"); more.id="more"; grid.appendChild(more);
  shown=0; appendWindow();
  moreObs.observe(more);
}
io=new IntersectionObserver((es)=>{for(const e of es)if(e.isIntersecting){io.unobserve(e.target);const img=e.target.querySelector("img");if(img&&img.dataset.src){img.src=img.dataset.src;img.onload=()=>img.classList.add("in");img.onerror=()=>img.remove();}}},{rootMargin:"600px"});
const moreObs=new IntersectionObserver((es)=>{for(const e of es)if(e.isIntersecting&&shown<view.length)appendWindow();},{rootMargin:"900px"});
addEventListener("scroll",()=>{ if(shown<view.length){const r=$("more").getBoundingClientRect();if(r.top<innerHeight+900)appendWindow();} },{passive:true});

// chips + search
for(const [code,label] of SYS){ const b=document.createElement("button"); b.className="chip"; b.dataset.code=code; b.textContent=label; b.onclick=()=>{cur=code;$("search").value="";render();}; $("sys").appendChild(b); }
let sT=0; $("search").addEventListener("input",()=>{clearTimeout(sT);sT=setTimeout(render,140);});
render();
</script>
