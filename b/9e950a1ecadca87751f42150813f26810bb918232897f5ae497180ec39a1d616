     resolved auth promise is handed to boot() below. Fail-SOFT: a gate that can't load drops the overlay
     and boot uses its device-stable identity, never bricked. -->
<script type="module">
  try {
    const { mountLogin } = await import("./holo-messenger-login.mjs?v=signin1");
