    for(let i=0;i<rec.length&&budget>0;i++){ const n=rec[i]; if(kindOf(n.name)!=="image") continue; budget--;
      try{ const {bytes,mime}=await HoloFiles.read(n,1<<20); const u=URL.createObjectURL(new Blob([bytes],{type:mime}));
