    <div class="qsec">${esc(sideCfg.places)}</div>
    <div class="qgrid" id="qgrid">${tiles.map((t,i)=>`
      <div class="qcard" data-ti="${i}"><span class="qi">${I[t.glyph]||I.folder}</span>
        <div><div class="qn">${esc(t.name)}</div><div class="qd">${esc(t.sub)}</div></div></div>`).join("")}
      ${door?`<div class="qcard qdoor" id="qdoor"><span class="qi">${I.plus}</span><div><div class="qn">${esc(door.name)}</div><div class="qd">${esc(door.role||"")}</div></div></div>`:""}
