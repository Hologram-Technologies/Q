}
function renderCrumbs(){
  const c = $("#crumbs");
  if(isHome()){ c.innerHTML = `<span class="crumb root">${I.home}<span>Home</span></span>`; return; }
  c.innerHTML = trail.map((n,i)=>{
    const g = n.kind==="location" ? (I[n.glyph]||I.drive) : "";
    return `<span class="crumb${i===0?' root':''}" data-i="${i}">${g}<span>${esc(n.name)}</span></span>${i<trail.length-1?`<span class="sep">${I.chev.replace(/width="2"/, 'width="1.6"')}</span>`:""}`;
  }).join("");
  $$("#crumbs .crumb").forEach(el=> el.dataset.i!=null && (el.onclick = ()=> crumbTo(+el.dataset.i)));
  c.onclick = (e)=>{ if(!e.target.closest(".crumb")) enterAddressEdit(); };   // click the empty bar → type a path
