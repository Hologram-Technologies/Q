/* ── file open → apps launch as holospaces; FILES open in Holo Quick Look (F3: open = resolve —
   the κ-projection preview IS the open surface; mediaURL re-derives sealed bytes before paint) ── */
function openFile(n){
  if(typeof pickMode!=="undefined" && pickMode && n.kind==="file"){ choosePick(n); return; }   // picker: double-click a file → choose it
  if(n.source==="trash"){ HoloFiles.restoreTrash(n).then(()=>{ listCache.clear(); render(); toast("Restored "+n.name); }); return; }
  if(n.source==="mount-connect" || n.source==="import-connect"){ drillInto(n); return; }   // the real-folder doors activate either way
  if(n.kind==="app" || n._appId){ launchHolospace(n._appId || n.role); return; }
  if(n.kind==="file"){ select(n); openProperties(n); return; }   // ONE PLANE (F3): open = resolve
  select(n);
}
function launchHolospace(id){ if(!id) return; try{ parent.postMessage({ type:"holo-open", id }, "*"); }catch{} toast("Opening "+id+" …"); }

/* ── new folder / rename / delete (Home + Desktop) — Desktop ops bridge to the shell (unification) ── */
$("#emptybin").onclick = async ()=>{ if(!confirm("Empty the Recycle Bin? This permanently deletes all items.")) return; await HoloFiles.emptyTrash(); listCache.clear(); render(); toast("Recycle Bin emptied"); };
// device write errors read clean: a 403 means the write capability isn't granted (keys-not-prompts).
const devErr=(e)=>{ const m=String(e&&e.message||e); return /403|refused/.test(m) ? "Device writes are off — grant permission to edit your disk" : "Couldn't complete: "+m; };
const isDevice=(n)=> !!(n && n._absPath);
const isMount=(n)=> !!(n && (String(n.path||"").startsWith("mount:") || String(n.path||"").startsWith("import:")));   // a real device file (live grant or opened snapshot)
$("#newfolder").onclick = async ()=>{ const n=cur(); const name = prompt("New folder name","untitled folder"); if(!name) return;
  if(n.source==="desktop"){ HoloFiles.deskMkdir(n, name); toast("Created "+name); return; }
  if(isDevice(n)){ try{ await HoloFiles.deviceMkdir(n._absPath, name); listCache.delete(n.id); render(); toast("Created "+name); }catch(e){ toast(devErr(e)); } return; }
  if(isMount(n)){ try{ await HoloFiles.mountMkdir(n.path, name); listCache.delete(n.id); render(); toast("Created "+name); }catch(e){ toast("Couldn't create: "+(e.message||e)); } return; }
  if(n.source!=="opfs") return; try{ await HoloFiles.mkdir(n.path, name); listCache.delete(n.id); render(); toast("Created "+name); }catch(e){ toast("Couldn't create: "+(e.message||e)); } };
async function renameSel(){ const n=sel; if(!n) return;
  if(n.source==="desktop"){ const name=prompt("Rename",n.name); if(!name||name===n.name) return; HoloFiles.deskRename(n,name); return; }
  if(isDevice(n)){ const name=prompt("Rename",n.name); if(!name||name===n.name) return; try{ await HoloFiles.deviceRename(n._absPath, name); listCache.delete(cur().id); sel=null; selSet.clear(); anchorIdx=-1; render(); toast("Renamed to "+name); }catch(e){ toast(devErr(e)); } return; }
  if(isMount(n)){ const name=prompt("Rename",n.name); if(!name||name===n.name) return; try{ await HoloFiles.mountRename(cur().path, n.name, name); listCache.delete(cur().id); sel=null; selSet.clear(); anchorIdx=-1; render(); toast("Renamed to "+name); }catch(e){ toast("Rename failed: "+(e.message||e)); } return; }
  if(n.source!=="opfs") return; const name=prompt("Rename",n.name); if(!name||name===n.name) return; const parent=cur(); try{ await HoloFiles.rename(parent.path, n.name, name); listCache.delete(parent.id); sel=null; selSet.clear(); anchorIdx=-1; render(); }catch(e){ toast("Rename failed: "+(e.message||e)); } }
/* ── clipboard: Cut / Copy / Paste (Home via OPFS · Desktop via the κ bridge) ── */
let clip=null;
const clipNodes=()=> selSet.size>1?selectedNodes():(sel?[sel]:[]);
function copySel(){ const ns=clipNodes(); if(!ns.length) return; clip={mode:"copy",nodes:ns,source:cur().source}; toast(`Copied ${ns.length} item${ns.length===1?"":"s"}`); }
function cutSel(){ const ns=clipNodes(); if(!ns.length) return; clip={mode:"cut",nodes:ns,source:cur().source}; markSelection(); toast(`Cut ${ns.length} item${ns.length===1?"":"s"} · paste to move`); }
async function uniqueName(name){ const have=new Set((await childrenOf(cur())).map(k=>k.name)); if(!have.has(name)) return name; const d=name.lastIndexOf("."); const b=d>0?name.slice(0,d):name, x=d>0?name.slice(d):""; let i=1,c; do{ c=`${b} (copy${i>1?" "+i:""})${x}`; i++; }while(have.has(c)); return c; }
async function pasteHere(){ if(!clip||!clip.nodes.length) return; const dest=cur();
  if(clip.source==="opfs" && dest.source==="opfs"){ let ok=0; for(const n of clip.nodes){ try{ if(clip.mode==="copy"){ await HoloFiles.copyHome(n.path, dest.path, await uniqueName(n.name)); } else { await HoloFiles.moveHome(n.path, dest.path); } ok++; }catch{} } listCache.clear(); if(clip.mode==="cut") clip=null; sel=null; selSet.clear(); render(); toast(`Pasted ${ok} item${ok===1?"":"s"}`); return; }
  if(clip.source==="desktop" && dest.source==="desktop"){ for(const n of clip.nodes){ clip.mode==="copy"?HoloFiles.deskCopy(n,dest):HoloFiles.deskMove(n,dest); } if(clip.mode==="cut") clip=null; toast("Pasted"); return; }
  if(isDevice(dest) && clip.nodes.every(isDevice)){ let ok=0; for(const n of clip.nodes){ try{ clip.mode==="copy" ? await HoloFiles.deviceCopy(n._absPath, dest._absPath) : await HoloFiles.deviceMove(n._absPath, dest._absPath); ok++; }catch(e){ toast(devErr(e)); } } listCache.clear(); if(clip.mode==="cut") clip=null; sel=null; selSet.clear(); render(); toast(`Pasted ${ok} item${ok===1?"":"s"}`); return; }
  toast("Paste across these locations isn't supported yet"); }
async function deleteSel(){ const all=(selSet.size>1?selectedNodes():(sel?[sel]:[]));
  const desk=all.filter(n=>n.source==="desktop"); if(desk.length){ if(!confirm(`Delete ${desk.length===1?desk[0].name:desk.length+" items"} from the desktop?`)) return; desk.forEach(n=>HoloFiles.deskRemove(n)); sel=null; selSet.clear(); toast(`Deleted ${desk.length} item${desk.length===1?"":"s"}`); return; }
  const tr=all.filter(n=>n.source==="trash"); if(tr.length){ if(!confirm(`Permanently delete ${tr.length===1?tr[0].name:tr.length+" items"}? This cannot be undone.`)) return; for(const n of tr){ try{ await HoloFiles.removeTrash(n); }catch{} } listCache.clear(); sel=null; selSet.clear(); render(); toast(`Permanently deleted ${tr.length} item${tr.length===1?"":"s"}`); return; }
  const dev=all.filter(isDevice); if(dev.length){ if(!confirm(`Delete ${dev.length===1?dev[0].name:dev.length+" items"}? Moves to the Recycle Bin.`)) return; let ok=0; for(const n of dev){ try{ await HoloFiles.deviceDelete(n._absPath); ok++; }catch(e){ toast(devErr(e)); } } listCache.clear(); sel=null; selSet.clear(); render(); toast(`Moved ${ok} item${ok===1?"":"s"} to the Recycle Bin`); return; }
  const mnt=all.filter(isMount); if(mnt.length){ if(!confirm(`Permanently delete ${mnt.length===1?mnt[0].name:mnt.length+" items"} from your device? This folder is real — there is no Recycle Bin here.`)) return; let ok=0; for(const n of mnt){ try{ const parts=String(n.path).split("/"); const nm=parts.pop(); await HoloFiles.mountRemove(parts.join("/"), nm); ok++; }catch(e){ toast("Couldn't delete: "+(e.message||e)); } } listCache.clear(); sel=null; selSet.clear(); render(); toast(`Deleted ${ok} item${ok===1?"":"s"}`); return; }
  const sn=all.filter(n=>n.source==="opfs"); if(!sn.length) return; let ok=0; for(const n of sn){ try{ await HoloFiles.recycle(n); ok++; }catch{} } listCache.clear(); sel=null; selSet.clear(); render(); toast(`Moved ${ok} item${ok===1?"":"s"} to Recycle Bin · ⌘Z or Recycle Bin to restore`); }

/* ── context menu ───────────────────────────────────────────────────────────────────── */
function openCtx(e,n,pane='a'){
  const m=$("#ctx"); const writable = (n.source==="opfs" || isDevice(n) || isMount(n)) && pane==='a';     // editable: Home (OPFS) + the device (bridge or web mounts)
  const drill = pane==='b'?drillP2:drillInto, pick = pane==='b'?selectP2:select;
  const cloudable = n.kind==="file" && (n.source==="opfs"||n.did||n._realPath) && n.source!=="cloud";
  const addressable = n.did||n.source==="opfs"||n.source==="cloud";
  const mi=(ic,label,fn,cls="")=>({ic,label,fn,cls});
  const items=[
    mi(I.open, (n.kind==="dir"||n.kind==="app")?"Open":"Select", ()=> (n.kind==="dir"||n.kind==="app")?drill(n):pick(n)),
    ...(n._appId||n.kind==="app"?[mi(I.open,"Open ↗",()=>launchHolospace(n._appId||n.role))]:[]),
