/* ── native sidebar — the host file manager's PLACES, not Hologram internals ──────────────────
   Lead with the user's real folders (Desktop/Downloads/…) + drives, exactly like Explorer/Finder/Files.
   The Hologram-internal locations (the κ graph, Holospaces, OS Runtime, the OPFS sandbox) are DEMOTED
   into one collapsed "Hologram" disclosure at the bottom — a power user expands it; a new user never
   sees jargon. Native group labels per OS. The known folders + drives load async from the host. */
const sideCfg = { places: PF.places || "Quick access", drives: PF.drives || "This PC" };   // N3: from the ONE idiom table
let nativePlaces = { folders:[], drives:[] };   // real device folders + volumes (loaded from the host)
let holoOpen = localStorage.getItem("holo.files.holoOpen")==="1";   // the demoted "Hologram" group
let _sideNodes = [];
async function loadNativePlaces(){
  try{ nativePlaces.folders = await HoloFiles.knownFolders(); }catch{ nativePlaces.folders=[]; }
  try{ const dev = LOCS.find(l=>l.source==="device"); nativePlaces.drives = dev ? await HoloFiles.list(dev) : []; }catch{ nativePlaces.drives=[]; }
  renderSide();
}
// the LOCS to demote into the Hologram group, with native-clean relabels for the two that would clash.
const HOLO_GROUP = () => LOCS.map(l=> l.source==="opfs"?{...l,name:"Holo Home"} : l.source==="desktop"?{...l,name:"Holo Desktop"} : l)
  .filter(l=> l.source!=="device");   // "This Device" is represented natively by the places above
function renderSide(){
  const side = $("#side"); _sideNodes=[];
  const used={}; for(const k in tagStore) for(const id of tagStore[k]) used[id]=(used[id]||0)+1;
  const tagItems = TAGS.filter(t=>used[t.id]);
  const item = (n,label,glyph,extra="") => { const i=_sideNodes.push(n)-1; return `<div class="sitem" data-si="${i}" ${extra}><span class="si-ico">${I[glyph]||I.folder}</span><span>${esc(label)}</span></div>`; };
  const grp = (label) => label?`<div class="sgroup">${esc(label)}</div>`:"";
  let html = "";
  // 1) the user's real folders (Home/Desktop/Downloads/Documents/Pictures/Music/Videos)
  if(nativePlaces.folders.length){ html += grp(sideCfg.places) + nativePlaces.folders.map(n=> item(n, n.name, n.glyph||"folder")).join(""); }
  // 1b) the SOVEREIGN views — what arrived across your life (chats · email · received), straight
  // from the home index; reads like an inbox, no new storage behind it.
  try{ html += HoloFiles.smartLocations().map(l=> item(l, l.name, l.glyph||"folder")).join(""); }catch{}
  // 2) drives (This PC / Locations)
  if(nativePlaces.drives.length){ html += grp(sideCfg.drives) + nativePlaces.drives.map(n=> item(n, n.name, "drive")).join(""); }
  // fallback while the host loads (or an older host with no userdirs): show the raw locations so it never blanks
  if(!nativePlaces.folders.length && !nativePlaces.drives.length){ html += grp(sideCfg.drives) + LOCS.filter(l=>l.source==="device").map(l=>item(l,l.name,l.glyph||"drive")).join(""); }
  // 3) tags (if any are in use)
  if(tagItems.length){ html += grp("Tags") + tagItems.map(t=>`<div class="sitem tagitem" data-tag="${t.id}"><span class="si-ico"><i class="td" style="background:${t.color};width:11px;height:11px"></i></span><span>${esc(t.name)}</span><small>${used[t.id]}</small></div>`).join(""); }
