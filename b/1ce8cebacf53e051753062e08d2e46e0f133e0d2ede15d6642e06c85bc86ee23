function infoCardHTML(n){
  return `<div class="qlinfo"><span class="bigglyph" style="color:${tint(n)}">${glyphFor(n)}</span><div><div style="font-weight:650;font-size:16px">${esc(n.name)}</div><div style="color:var(--faint);font-size:13px;margin-top:4px">${typeLabel(n)}${n.bytes!=null?" · "+fmtBytes(n.bytes):""}</div></div><pre class="qlhex" id="qlhex">…</pre></div>`;
}
function hexDump(bytes){ const N=Math.min(bytes.length,256); let out=""; for(let o=0;o<N;o+=16){ const row=[...bytes.slice(o,o+16)]; const hex=row.map(b=>b.toString(16).padStart(2,"0")).join(" ").padEnd(47); const asc=row.map(b=>b>=32&&b<127?String.fromCharCode(b):".").join(""); out+=o.toString(16).padStart(6,"0")+"  "+hex+"  "+asc+"\n"; } return out; }
function renderMarkdown(md){
  const blocks=[]; md=String(md).replace(/```([\s\S]*?)```/g,(_,c)=>{ blocks.push(c); return "␀"+(blocks.length-1)+"␀"; });
  let h=esc(md)
    .replace(/^###### (.*)$/gm,"<h6>$1</h6>").replace(/^##### (.*)$/gm,"<h5>$1</h5>").replace(/^#### (.*)$/gm,"<h4>$1</h4>")
    .replace(/^### (.*)$/gm,"<h3>$1</h3>").replace(/^## (.*)$/gm,"<h2>$1</h2>").replace(/^# (.*)$/gm,"<h1>$1</h1>")
    .replace(/\*\*([^*]+)\*\*/g,"<strong>$1</strong>").replace(/\*([^*]+)\*/g,"<em>$1</em>").replace(/`([^`]+)`/g,"<code>$1</code>")
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g,'<a href="$2" target="_blank" rel="noopener">$1</a>')
    .replace(/^\s*[-*] (.*)$/gm,"<li>$1</li>").replace(/(<li>[\s\S]*?<\/li>)/g,"<ul>$1</ul>").replace(/\n{2,}/g,"</p><p>");
  h=("<p>"+h+"</p>").replace(/␀(\d+)␀/g,(_,i)=>`<pre><code>${esc(blocks[+i]||"")}</code></pre>`);
  return h;
}
function zipListHTML(bytes,n){
