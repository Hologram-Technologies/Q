// the file's bytes as a fetchable URL — by κ when known (verified + range-streamable), else an object URL.
async function mediaURL(n){
  const key=n.did?String(n.did).split(":").pop():("p:"+(n.path||n.name));
  if(previewURLCache.has(key)) return previewURLCache.get(key);
  const rp=HoloFiles.realPath(n);
  if(rp){ previewURLCache.set(key,rp); return rp; }
  try{ const {bytes,mime}=await HoloFiles.read(n,256*1024*1024);
    // F3 verify-before-render: a Home file wearing a κ must RE-DERIVE before it paints (Law L5) —
    // drifted bytes refuse (honest empty + toast) instead of rendering under their old identity.
    if(n.did && n.source==="opfs"){ const got=await sha256hexLocal(bytes); if(got!==String(n.did).split(":").pop()){ toast("Refused — bytes no longer match this file's κ"); return ""; } }
    const u=URL.createObjectURL(new Blob([bytes],{type:mime||"application/octet-stream"})); previewURLCache.set(key,u); return u; }catch{ return ""; }
}
// route any type → a viewable projection
async function previewFor(n){
  const k=kindOf(n.name), ext=extOf(n.name);
  if(k==="image"||ext==="svg") return { html:`<img class="qlimg" alt="">`, mount:async(s)=>{ const im=s.querySelector("img"); if(im) im.src=await mediaURL(n); } };
  if(k==="video") return { html:`<video controls autoplay playsinline></video>`, mount:async(s)=>{ const v=s.querySelector("video"); if(v) v.src=await mediaURL(n); } };
  if(k==="audio") return { html:`<div class="qlinfo"><span class="bigglyph" style="color:${tint(n)}">${I.audio}</span><audio controls autoplay></audio></div>`, mount:async(s)=>{ const a=s.querySelector("audio"); if(a) a.src=await mediaURL(n); } };
  if(ext==="pdf") return { html:`<iframe title="PDF"></iframe>`, mount:async(s)=>{ const f=s.querySelector("iframe"); if(f) f.src=await mediaURL(n); } };
  if(ext==="md"||ext==="markdown") return memoPreview(n,"md",1<<20, b=>`<div class="qlmd">${renderMarkdown(new TextDecoder().decode(b))}</div>`);
  if(ext==="html"||ext==="htm") return { html:`<iframe sandbox title="HTML"></iframe>`, mount:async(s)=>{ const f=s.querySelector("iframe"); if(!f) return; const {bytes}=await HoloFiles.read(n,2*1024*1024); f.srcdoc=new TextDecoder().decode(bytes); } };
  if(k==="code"||k==="text"||k==="data") return { html:`<pre class="qltext"></pre>`, mount:async(s)=>{ const p=s.querySelector("pre"); if(!p) return; const {bytes}=await HoloFiles.read(n,512*1024); p.textContent=new TextDecoder().decode(bytes); } };
  if(["zip","jar","apk","war","ipa"].includes(ext)) return memoPreview(n,"zip",64*1024*1024, b=>zipListHTML(b,n));
  if(["ttf","otf","woff","woff2"].includes(ext)) return fontPreview(n);
  return { html:infoCardHTML(n), mount:async(s)=>{ try{ const {bytes}=await HoloFiles.read(n,1024); const el=s.querySelector("#qlhex"); if(el) el.textContent=hexDump(bytes); }catch{} } };
}
// previewκ = f(sourceκ, renderer): derive ONCE per content, reuse forever (the ingenious core).
function memoPreview(n, rid, cap, fn){
  const key=(n.did?String(n.did).split(":").pop():("p:"+(n.path||n.name)))+":"+rid;
  if(previewMemo.has(key)) return { html:previewMemo.get(key) };
  return { html:`<div class="qlshim">Rendering…</div>`, mount:async(s,_n,alive)=>{ try{ const {bytes}=await HoloFiles.read(n,cap); const html=fn(bytes); previewMemo.set(key,html); if(!alive||alive()) s.innerHTML=html; }catch{ if(!alive||alive()) s.innerHTML=infoCardHTML(n); } } };
}
async function fontPreview(n){
  return { html:`<div class="qlshim">Loading font…</div>`, mount:async(s,_n,alive)=>{
    try{ const {bytes}=await HoloFiles.read(n,16*1024*1024); const fam="qlf"+(qlShow._t||0); const ff=new FontFace(fam, bytes.buffer.slice(bytes.byteOffset,bytes.byteOffset+bytes.byteLength)); await ff.load(); document.fonts.add(ff);
      const pangram="The quick brown fox jumps over the lazy dog 0123456789";
      const html=`<div class="qlfontspec" style="font-family:'${fam}'"><div class="fline" style="font-size:52px">AaBbCcDdEeFfGg</div><div class="fline" style="font-size:28px">abcdefghijklmnopqrstuvwxyz</div><div class="fline" style="font-size:28px">ABCDEFGHIJKLMNOPQRSTUVWXYZ</div>`+[40,28,20,15].map(sz=>`<div class="fline" style="font-size:${sz}px">${esc(pangram)}</div>`).join("")+`</div>`;
