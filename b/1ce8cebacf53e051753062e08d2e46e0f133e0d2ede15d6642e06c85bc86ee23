<!-- ── Holo UI standardization — composed from CANONICAL SHELL OBJECTS ────────────────────────
       Not a per-app facade: Holo Files renders the first-party shell objects from apps/ui (Tile,
       StatusBar) BY THEIR κ, via window.HoloRender. One source of truth, themed by --holo-* tokens,
       rendered with no compile on the hot path (warm rebind is sub-ms, so the status bar re-renders
       freely). The native quick-access tiles + status spans remain as a pre-HoloRender fallback only.
       Stateful / bidirectional controls (search · views · sort · Verify) stay native by design. -->
<script type="module">
  const SHELL = {
    tile:      "holo://sha256:ff5ef77e183baa5bf9d3d25da2c20f876e652f9d9faa3fdfff444e660109b36b",
    statusbar: "holo://sha256:00304bda8f4ccddcf79d2ad1488ad25cf3ff5d8eced6bc2231728661c96530bb",
  };
  const ready = async () => { for (let i = 0; i < 160 && !window.HoloRender; i++) await new Promise((r) => setTimeout(r, 50)); return window.HoloRender || null; };
  const shieldSvg = () => { const b = document.querySelector("#status .badge svg"); return b ? b.outerHTML : ""; };

  // the Home quick-access tiles → the canonical Tile object (rebuilt one-way each Home visit; we read
  // the painted native tile so the live "N apps" count + glyph carry over, then delegate the click)
  function facadeCards() {
    const HR = window.HoloRender; if (!HR) return;
    document.querySelectorAll("#qgrid .qcard").forEach((orig) => {
      if (orig.dataset.holoUi) return; orig.dataset.holoUi = "1";
      const icon = (orig.querySelector(".qi") || {}).innerHTML || "";
      const title = (orig.querySelector(".qn") || {}).textContent || "";
      const subtitle = (orig.querySelector(".qd") || {}).textContent || "";
      const trailing = (orig.querySelector(".qx") || {}).textContent || "";
      const s = document.createElement("div"); orig.style.display = "none"; orig.after(s);
      HR.render(s, SHELL.tile, { props: { icon, title, subtitle, trailing, onClick: () => orig.click() } })
        .catch(() => { orig.style.display = ""; s.remove(); orig.dataset.holoUi = ""; });
    });
  }

  // the status bar stays NATIVE (the host's "N items" footer) — the canonical κ-StatusBar object renders a
  // "content-addressed" badge, which is exactly the jargon Native-First-Run hides. The plain #status spans
  // (set by setStatus) already read like Explorer/Finder, so we let them own the bar. (Invisible κ.)
  async function statusRender() { return false; }

  window.HoloFacade = { cards: facadeCards, status: statusRender };
  (async () => { const HR = await ready(); if (!HR) return; facadeCards(); if (window.__lastFilesStatus) statusRender(window.__lastFilesStatus); })();
</script>
</body>
</html>
