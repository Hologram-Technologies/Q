function applyTab(){ const t=tabs[activeTab]; if(!t) return; trail=t.trail; histBack=t.histBack; histFwd=t.histFwd; view=t.view; sel=t.sel; selSet=t.selSet; sortKey=t.sortKey; sortDir=t.sortDir; reflectView(); }
