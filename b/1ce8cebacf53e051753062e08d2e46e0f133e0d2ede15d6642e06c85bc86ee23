async function doVerify(n, btn){
  btn.disabled=true; const box=$("#dprev"); const rip=document.createElement("div"); rip.className="ripple"; box&&box.appendChild(rip); setTimeout(()=>rip.remove(),900);
  btn.innerHTML = I.shield+"<span>Verifying…</span>";
  let r; try{ r = await HoloFiles.verify(n); }catch(e){ r={ok:false, reason:e.message||String(e)}; }
  btn.disabled=false;
  if(r.ok===true){ btn.className="kverify ok"; btn.innerHTML=I.verified+"<span>Verified</span>"; toast("✓ "+n.name+" verified"); }
  else if(r.ok===false){ btn.className="kverify bad"; btn.innerHTML=I.x+"<span>Doesn't match</span>"; toast("✗ "+(r.reason||"content mismatch")); }
  else { btn.className="kverify"; btn.innerHTML=I.shield+"<span>"+(r.reason||"not verifiable")+"</span>"; toast(r.reason||"nothing to verify"); }
}

/* ── Home landing page ──────────────────────────────────────────────────────────────── */
/* ── EXPLORER HOME (E2): the first paint IS your computer — real folders as tiles, real files
   with real dates and thumbnails in Recent. Blueprint: files-community/Files' Home (Quick access
   + Recent). Hologram's own locations stay in the sidebar; so does every trace of jargon. ── */
async function gatherRecent(limit=20){
  const roots=[];
  for(const d of ["Desktop","Documents","Downloads","Pictures","Music","Videos","Media"]) roots.push({path:"/home/user/"+d,kind:"dir",source:"opfs"});
  try{ const dev=await HoloFiles.list({path:"device:",kind:"location",source:"device"});
    for(const r of dev) if(r.source==="mount-dir"||r.source==="import-dir") roots.push(r); }catch{}
  const out=[];
  for(const r of roots.slice(0,14)){ try{ for(const n of await HoloFiles.list(r)) if(n.kind==="file"&&n.mtime) out.push(Object.assign(n,{_parent:r.name||r.path.split("/").pop()})); }catch{} }
  return out.sort((a,b)=>(b.mtime||0)-(a.mtime||0)).slice(0,limit);
}
