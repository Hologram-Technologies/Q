  if(k==="image"){ try{ const {bytes,mime}=await HoloFiles.read(n, 1<<20); const url=URL.createObjectURL(new Blob([bytes],{type:mime})); box.innerHTML=`<img src="${url}" alt="">`; }catch{} }
