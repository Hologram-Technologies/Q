<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<title>Holo Files the native explorer for Hologram OS</title>
<link rel="icon" href="icon.svg" />
<link rel="stylesheet" href="../../_shared/holo-mobile.css" />
<!-- Holo UI (theme/look engine) + Holo UX (device-tier profile) — every object wears the one design
     system, and the host's native feel is resolved from holo-platform. No framework, no CDN (Law L4). -->
<!-- The ONE embed guard (holo-embed.js): sets html[data-embedded] before paint when hosted in the
     shell, so Files drops its own tab strip and never double-draws the frame. Standalone keeps it. -->
<script src="../../_shared/holo-embed.js"></script>
<script src="../../_shared/holo-ui-kernel.js"></script>
<script type="module" src="../../_shared/holo-ux.js"></script>
<script type="module" src="../../_shared/holo-object.js"></script>
<!-- Holo Cloud's data layer (HoloWebDAV, classic global) — so Files mounts the SAME content-addressed
     OPFS κ-store the Holo Cloud app uses: a file sent here appears there and vice versa. -->
<script src="../../_shared/holo-webdav.js"></script>
<style>
  :root{
    color-scheme: dark;
    --accent:#3aa0ff; --accent-ink:#fff;
    --bg:#0b0f17; --chrome:#0e131dF2; --panel:#121826; --panel2:#161d2c; --hover:#1b2433; --sel:#1f3553;
    --line:#222c3d; --line2:#2c3850; --ink:#e6ecf5; --dim:#9aa7bd; --faint:#6b7890;
    --ok:#34d399; --bad:#fb6f7d; --warn:#f5b545;
    --mono:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;
    --sys:system-ui,-apple-system,"Segoe UI",Roboto,sans-serif;
    --r:10px; --side-w:236px; --details-w:300px; --row-h:30px;
  }
  *{box-sizing:border-box}
  html,body{margin:0;height:100%;overflow:hidden}
  body{background:var(--bg);color:var(--ink);font:var(--holo-text-sm, 1rem)/1.5 var(--sys);-webkit-font-smoothing:antialiased;
    display:flex;flex-direction:column;user-select:none}
  button{font:inherit;color:inherit;background:none;border:0;cursor:pointer}
  ::-webkit-scrollbar{width:11px;height:11px}::-webkit-scrollbar-thumb{background:#33415a;border:3px solid transparent;background-clip:content-box;border-radius:99px}
  ::-webkit-scrollbar-thumb:hover{background:#46587a;background-clip:content-box}

  /* ── command bar (the toolbar + breadcrumb address bar) ─────────────────────────────── */
  #bar{display:flex;align-items:center;gap:8px;padding:7px 10px;background:var(--chrome);border-bottom:1px solid var(--line);
    backdrop-filter:blur(14px);flex:0 0 auto;height:46px}
  .nav{display:flex;gap:2px}
  .ico{width:30px;height:30px;border-radius: var(--holo-radius-sm, 8px);display:grid;place-items:center;color:var(--dim)}
  .ico:hover{background:var(--hover);color:var(--ink)} .ico:disabled{opacity:.32;background:none;cursor:default}
  .ico svg{width:17px;height:17px}
  #crumbs{flex:1;display:flex;align-items:center;gap:1px;min-width:0;height:30px;padding:0 6px;background:var(--panel);
    border:1px solid var(--line);border-radius: var(--holo-radius-sm, 8px);overflow:hidden}
  .crumb{display:flex;align-items:center;gap:5px;padding:3px 7px;border-radius:6px;color:var(--ink);white-space:nowrap;font-size: var(--holo-text-sm, 1rem)}
  .crumb:hover{background:var(--hover)} .crumb .sep{color:var(--faint);margin:0 -2px} .crumb.root{color:var(--dim)}
  .addrinput{flex:1;width:100%;background:transparent;border:0;outline:none;color:var(--ink);font:inherit;height:100%;padding:0 4px}
  .crumb svg{width:14px;height:14px;opacity:.85}
  #search{display:flex;align-items:center;gap:6px;width:200px;height:30px;padding:0 9px;background:var(--panel);
    border:1px solid var(--line);border-radius: var(--holo-radius-sm, 8px);color:var(--dim);transition:width .15s,border-color .15s}
  #search:focus-within{border-color:var(--accent);width:240px} #search input{flex:1;background:none;border:0;color:var(--ink);outline:none;font:inherit;min-width:0}
  #search svg{width:15px;height:15px}
  .views{display:flex;gap:1px;background:var(--panel);border:1px solid var(--line);border-radius: var(--holo-radius-sm, 8px);padding:2px}
  .vbtn{width:28px;height:24px;border-radius:6px;display:grid;place-items:center;color:var(--dim)}
  .vbtn:hover{color:var(--ink)} .vbtn.on{background:var(--accent);color:var(--accent-ink)} .vbtn svg{width:15px;height:15px}

  /* ── body: sidebar · main · details ─────────────────────────────────────────────────── */
  #body{flex:1;display:flex;min-height:0}
  #side{width:var(--side-w);flex:0 0 auto;background:var(--chrome);border-right:1px solid var(--line);overflow-y:auto;padding:8px 8px 20px}
  .sgroup{margin:6px 4px 4px;font:600 var(--holo-text-sm, 1rem) var(--sys);letter-spacing:.06em;text-transform:uppercase;color:var(--faint)}
  .sitem{display:flex;align-items:center;gap:9px;padding:7px 9px;border-radius: var(--holo-radius-sm, 8px);color:var(--ink);cursor:pointer;font-size: var(--holo-text-sm, 1rem)}
  .sitem:hover{background:var(--hover)} .sitem.on{background:var(--sel)} .sitem.on .si-ico{color:var(--accent)}
  .si-ico{width:18px;height:18px;flex:0 0 auto;color:var(--dim);display:grid;place-items:center} .si-ico svg{width:18px;height:18px}
  .sitem small{margin-left:auto;color:var(--faint);font:var(--holo-text-sm, 1rem) var(--mono)}
  /* the demoted "Hologram" group header — collapsible, jargon lives below it only */
  .sgroup.holohdr{cursor:pointer;display:flex;align-items:center;gap:5px;user-select:none}
  .sgroup.holohdr:hover{color:var(--dim)} .hchev{display:inline-flex;width:12px;height:12px;transition:transform .15s}
  .hchev svg{width:12px;height:12px} .hchev.open{transform:rotate(90deg)}

  #main{flex:1;min-width:0;display:flex;flex-direction:column;background:var(--bg)}
  #list{flex:1;overflow:auto;position:relative}

  /* table / details view */
  table.det{width:100%;border-collapse:collapse;font-size: var(--holo-text-sm, 1rem)}
  table.det thead th{position:sticky;top:0;background:var(--bg);text-align:left;color:var(--faint);font-weight:600;
    padding:7px 10px;border-bottom:1px solid var(--line);z-index:2;font-size: var(--holo-text-sm, 1rem);cursor:pointer;white-space:nowrap}
  table.det thead th:hover{color:var(--ink)}
  table.det td{padding:0 10px;height:var(--row-h);border-bottom:1px solid #ffffff08;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:0}
  table.det tr{cursor:default} table.det tbody tr:hover{background:var(--hover)} table.det tr.sel{background:var(--sel)!important}
  /* P6 virtualization — the browser skips layout/paint of off-screen rows (huge folders open instantly, scroll at 60fps) */
  table.det tbody tr{content-visibility:auto;contain-intrinsic-size:auto var(--row-h)}
  .nm{display:flex;align-items:center;gap:9px;min-width:0} .nm .gl{width:18px;height:18px;flex:0 0 auto}
  .nm .t{overflow:hidden;text-overflow:ellipsis} .kcell{font:var(--holo-text-sm, 1rem) var(--mono);color:var(--accent);opacity:.85}
  .vchip{display:inline-flex;align-items:center;gap:4px;font:var(--holo-text-sm, 1rem) var(--mono);color:var(--faint)}
  .vchip.ok{color:var(--ok)} .vchip.bad{color:var(--bad)} .vchip svg{width:12px;height:12px}

  /* list (compact) */
  .listv{padding:6px} .lrow{display:flex;align-items:center;gap:10px;padding:6px 9px;border-radius:7px;cursor:default;content-visibility:auto;contain-intrinsic-size:auto 34px}
  .lrow:hover{background:var(--hover)} .lrow.sel{background:var(--sel)} .lrow .meta{margin-left:auto;color:var(--faint);font:var(--holo-text-sm, 1rem) var(--mono)}

  /* grid / tiles */
  .grid{display:grid;gap:10px;padding:14px}
  .grid.icons{grid-template-columns:repeat(auto-fill,minmax(108px,1fr))}
  .grid.tiles{grid-template-columns:repeat(auto-fill,minmax(230px,1fr))}
  .cell{border-radius:11px;padding:14px 10px;display:flex;flex-direction:column;align-items:center;gap:9px;cursor:default;text-align:center;border:1px solid transparent;content-visibility:auto;contain-intrinsic-size:auto 116px}
  .grid.tiles .cell{contain-intrinsic-size:auto 64px}
  .cell:hover{background:var(--hover)} .cell.sel{background:var(--sel);border-color:var(--line2)}
  .cell .gl{width:46px;height:46px} .cell .cn{font-size: var(--holo-text-sm, 1rem);line-height:1.3;word-break:break-word;max-width:100%}
  /* κ-keyed thumbnails: an image cell's glyph is replaced by an <img> of its own bytes (loaded lazily) */
  .cell .gl{position:relative}
  .cell .gl img.thumb{width:100%;height:100%;object-fit:cover;border-radius: var(--holo-radius-sm, 8px);display:block;background:#0c1220} .grid.tiles .gl img.thumb{border-radius:6px}
  .vbadge{position:absolute;right:3px;bottom:3px;width:18px;height:18px;border-radius:50%;background:#000a;display:grid;place-items:center;color:#fff} .vbadge svg{width:11px;height:11px}
  /* folder peek: a live mosaic of the media inside a folder */
  .cell .gl .peek{display:grid;width:100%;height:100%;border-radius: var(--holo-radius-sm, 8px);overflow:hidden;gap:1px;background:#0c1220} .cell .gl .peek img{width:100%;height:100%;object-fit:cover}
  .peek.peek-1{grid-template-columns:1fr} .peek.peek-2{grid-template-columns:1fr 1fr} .peek.peek-3,.peek.peek-4{grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr} .peek.peek-3 img:first-child{grid-row:1/3}
  /* Q-SOUL: the quiet whisper (a fact, one line) · the preview card (what will change) · Undo */
  #whisper{display:none;align-items:center;gap:10px;margin:0 0 8px;padding:8px 12px;border-radius:10px;
    background:var(--panel2);border:1px solid var(--line2);color:var(--ink);font-size:var(--holo-text-sm,1rem)}
  #whisper.on{display:flex;animation:qsoul-in .16s var(--holo-ease,ease-out)}
  #whisper span{flex:1;min-width:0}
  #whisper button{border:0;border-radius:8px;padding:5px 11px;cursor:pointer;background:var(--accent);color:#fff;font:inherit}
  #whisper #wx{background:transparent;color:var(--faint);padding:5px 7px}
  #qplan{position:fixed;left:50%;bottom:26px;transform:translateX(-50%) translateY(8px);opacity:0;pointer-events:none;
    min-width:280px;max-width:min(440px,92vw);background:var(--panel);border:1px solid var(--line2);border-radius:14px;
    box-shadow:0 18px 60px #000a;padding:14px 16px;z-index:90;transition:opacity .15s var(--holo-ease,ease),transform .15s var(--holo-ease,ease)}
  #qplan.on{opacity:1;pointer-events:auto;transform:translateX(-50%) translateY(0)}
  #qplan .qpt{font-weight:600;margin-bottom:4px}
  #qplan .qpl{color:var(--dim);font-size:var(--holo-text-sm,1rem)}
  #qplan .qpr{display:flex;gap:8px;justify-content:flex-end;margin-top:12px}
  #qplan button{border:0;border-radius:9px;padding:7px 16px;cursor:pointer;font:inherit;background:var(--panel2);color:var(--ink)}
  #qplan #qpgo{background:var(--accent);color:#fff}
  #qundo{position:fixed;left:50%;bottom:26px;transform:translateX(-50%);display:none;border:0;border-radius:999px;
    padding:8px 20px;cursor:pointer;background:var(--panel);border:1px solid var(--line2);color:var(--ink);box-shadow:0 10px 34px #0009;z-index:89;font:inherit}
  #qundo.on{display:block;animation:qsoul-in .16s var(--holo-ease,ease-out)}
  @keyframes qsoul-in{from{opacity:0;transform:translateX(-50%) translateY(8px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}
  #whisper.on{animation:none}
  /* hover-to-play video */
  .cell .gl video.hoverplay{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;border-radius: var(--holo-radius-sm, 8px);background:#000;z-index:1}
  .grid.tiles .cell{flex-direction:row;align-items:center;text-align:left;padding:12px} .grid.tiles .gl{width:38px;height:38px;flex:0 0 auto}
  .grid.tiles .ct{min-width:0} .grid.tiles .cn{font-size: var(--holo-text-sm, 1rem)} .grid.tiles .csub{font:var(--holo-text-sm, 1rem) var(--mono);color:var(--accent);opacity:.8;margin-top:3px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

  /* columns (Finder miller view) */
  .cols{display:flex;height:100%;overflow-x:auto}
  .col{width:240px;flex:0 0 auto;border-right:1px solid var(--line);overflow-y:auto;padding:5px}
  .col .lrow.sel{background:var(--sel)}
  .col .chev{margin-left:auto;color:var(--faint)}

  /* ── Home landing page (the Files "Home" tab) ───────────────────────────────────────── */
  #homepg{padding:26px 30px;overflow:auto;height:100%}
  .hhead{display:flex;align-items:center;gap:14px;margin-bottom:4px}
  .hhead img{width:40px;height:40px} .hhead h1{font-size:20px;margin:0;font-weight:650}
  .hsub{color:var(--dim);margin:2px 0 22px;font-size: var(--holo-text-sm, 1rem)}
  .qsec{font:600 var(--holo-text-sm, 1rem) var(--sys);letter-spacing:.05em;text-transform:uppercase;color:var(--faint);margin:18px 0 10px}
  .qgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px}
  /* EXPLORER HOME (E2): Recent rows — name · where · date, thumbnail-ready */
  .qcard.qdoor{border-style:dashed;opacity:.85}
  .rrow{display:flex;align-items:center;gap:12px;padding:8px 10px;border-radius:9px;cursor:pointer}
  .rrow:hover{background:var(--panel2)}
  .rrow .rico{width:34px;height:34px;flex:0 0 auto;display:grid;place-items:center;color:var(--dim);overflow:hidden;border-radius:7px}
  .rrow .rico svg{width:22px;height:22px}
  .rrow .rico img{width:34px;height:34px;object-fit:cover;border-radius:7px}
  .rrow .rname{flex:0 1 auto;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .rrow .rwhere{flex:1;min-width:0;color:var(--faint);font-size:var(--holo-text-sm,1rem);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .rrow .rdate{flex:0 0 auto;color:var(--faint);font-size:var(--holo-text-sm,1rem)}
  .qcard{display:flex;align-items:center;gap:13px;padding:15px;background:var(--panel);border:1px solid var(--line);border-radius:13px;cursor:pointer;transition:transform .1s,border-color .1s,background .1s}
  .qcard:hover{transform:translateY(-1px);border-color:var(--line2);background:var(--panel2)}
  .qcard .qi{width:40px;height:40px;border-radius:10px;display:grid;place-items:center;background:#0c1220;border:1px solid var(--line);color:var(--accent)} .qcard .qi svg{width:21px;height:21px}
  .qcard .qn{font-weight:600;font-size: var(--holo-text-sm, 1rem)} .qcard .qd{color:var(--faint);font-size: var(--holo-text-sm, 1rem);margin-top:2px}
  .qcard .qx{margin-left:auto;color:var(--faint);font:var(--holo-text-sm, 1rem) var(--mono)}

  /* ── details pane ───────────────────────────────────────────────────────────────────── */
  #details{width:var(--details-w);flex:0 0 auto;background:var(--chrome);border-left:1px solid var(--line);overflow-y:auto;display:none}
  #details.on{display:block} body.nodet #details{display:none}
  .dprev{height:172px;display:grid;place-items:center;background:radial-gradient(120% 90% at 50% 0,#15203400,#0a0e16);border-bottom:1px solid var(--line);overflow:hidden}
  .dprev .gl{width:74px;height:74px} .dprev img,.dprev .codeprev{max-width:100%;max-height:100%}
  .codeprev{font:var(--holo-text-sm, 1rem)/1.45 var(--mono);color:var(--dim);padding:12px;white-space:pre;overflow:hidden;width:100%;height:100%}
  .dpad{padding:16px} .dname{font-size: var(--holo-text-sm, 1rem);font-weight:650;word-break:break-word;display:flex;align-items:center;gap:8px}
  .dmeta{margin-top:14px;display:grid;gap:10px}
  .drow{display:grid;gap:3px} .drow .l{font:600 var(--holo-text-sm, 1rem) var(--sys);text-transform:uppercase;letter-spacing:.05em;color:var(--faint)}
  .drow .v{font-size: var(--holo-text-sm, 1rem);word-break:break-all} .drow .v.k{font:var(--holo-text-sm, 1rem) var(--mono);color:var(--accent)}
  .vbtnbig{margin-top:16px;width:100%;display:flex;align-items:center;justify-content:center;gap:8px;padding:11px;border-radius:10px;
    background:var(--accent);color:var(--accent-ink);font-weight:600;border:1px solid var(--accent)}
  .vbtnbig:hover{filter:brightness(1.08)} .vbtnbig.ok{background:#0e2c22;border-color:var(--ok);color:var(--ok)} .vbtnbig.bad{background:#2c1014;border-color:var(--bad);color:var(--bad)}
  .vbtnbig svg{width:16px;height:16px}
  .lawnote{margin-top:10px;font-size: var(--holo-text-sm, 1rem);color:var(--faint);line-height:1.5}
  /* invisible-κ: content address is a quiet disclosure in Properties, never a headline */
  .kapparow{margin-top:16px;border-top:1px solid var(--line);padding-top:12px}
  .kappatoggle{display:flex;align-items:center;gap:6px;color:var(--faint);font:var(--holo-text-sm,1rem) var(--sys);background:none;border:0;cursor:pointer;padding:0}
  .kappatoggle:hover{color:var(--dim)} .kappatoggle .kchev{display:inline-flex;width:12px;height:12px;transition:transform .15s}
  .kappatoggle .kchev svg{width:12px;height:12px} .kappatoggle .kchev.open{transform:rotate(90deg)}
  .kappabody{margin-top:8px} .kval{font:var(--holo-text-sm,1rem) var(--mono);color:var(--dim);word-break:break-all}
  .kverify{margin-top:10px;display:inline-flex;align-items:center;gap:6px;padding:6px 12px;border-radius: var(--holo-radius-sm, 8px);border:1px solid var(--line2);color:var(--dim);background:var(--panel)}
  .kverify:hover{color:var(--ink);border-color:var(--accent)} .kverify svg{width:13px;height:13px} .kverify.ok{color:var(--ok);border-color:var(--ok)} .kverify.bad{color:var(--bad);border-color:var(--bad)}

  /* the κ re-derive ripple — a little magic when verifying (Law L5) */
  @keyframes ripple{0%{transform:scale(.4);opacity:.55}100%{transform:scale(2.4);opacity:0}}
  .ripple{position:absolute;inset:0;margin:auto;width:60px;height:60px;border-radius:50%;border:2px solid var(--accent);pointer-events:none;animation:ripple .9s ease-out forwards}

  /* ── status bar ─────────────────────────────────────────────────────────────────────── */
  #status{flex:0 0 auto;display:flex;align-items:center;gap:14px;height:26px;padding:0 12px;background:var(--chrome);
    border-top:1px solid var(--line);color:var(--faint);font:var(--holo-text-sm, 1rem) var(--sys)}
  #status .sp{margin-left:auto} #status b{color:var(--dim);font-weight:600} #status .k{color:var(--accent);font-family:var(--mono)}
  #status .badge{display:inline-flex;align-items:center;gap:5px;color:var(--ok)} #status .badge svg{width:12px;height:12px}

  /* empty + toast + context menu */
  .empty{position:absolute;inset:0;display:grid;place-content:center;text-align:center;color:var(--faint);gap:14px;padding:30px}
  .empty .ebtn{display:inline-flex;gap:8px;align-items:center;padding:9px 16px;border-radius:9px;background:var(--accent);color:var(--accent-ink);font-weight:600}
  #toast{position:fixed;left:50%;bottom:42px;transform:translate(-50%,12px);background:#0d1220f5;border:1px solid var(--line2);border-radius:99px;
    padding:8px 16px;font-size: var(--holo-text-sm, 1rem);opacity:0;pointer-events:none;transition:.18s;z-index:60;box-shadow:0 10px 30px #0008}
  #toast.show{opacity:1;transform:translate(-50%,0)}
  #ctx{position:fixed;z-index:70;min-width:188px;background:#0e1422f7;border:1px solid var(--line2);border-radius:10px;padding:5px;
    box-shadow:0 16px 50px #000a;backdrop-filter:blur(12px);display:none}
  #ctx.on{display:block} .mi{display:flex;align-items:center;gap:10px;padding:8px 11px;border-radius:7px;font-size: var(--holo-text-sm, 1rem);cursor:pointer}
  .mi:hover{background:var(--accent);color:var(--accent-ink)} .mi.sepb{border-top:1px solid var(--line);margin-top:4px;padding-top:10px}
  .mi svg{width:15px;height:15px;opacity:.85} .mi.danger{color:var(--bad)} .mi.danger:hover{background:var(--bad);color:#fff}
  /* the two consolidating popovers (view · ⋯) — abstract the toolbar's many controls into two buttons */
  .popmenu{position:fixed;z-index:70;min-width:208px;background:#0e1422f7;border:1px solid var(--line2);border-radius:10px;padding:5px;
    box-shadow:0 16px 50px #000a;backdrop-filter:blur(12px);display:none}
  .popmenu.on{display:block}
  .popmenu .views{display:flex;flex-direction:column;gap:1px}
  .popmenu .mi,.popmenu .vbtn{width:100%;height:auto;justify-content:flex-start;gap:10px;padding:8px 11px;border-radius:7px;
    background:none;border:0;color:var(--ink);font:inherit;text-align:left;cursor:pointer}
  .popmenu .mi span,.popmenu .vbtn span{font-size:var(--holo-text-sm,1rem)}
  .popmenu .mi:hover,.popmenu .vbtn:hover{background:var(--accent);color:var(--accent-ink)}
  .popmenu .vbtn.on{background:var(--accent);color:var(--accent-ink)}
  .popmenu .mi svg,.popmenu .vbtn svg{width:16px;height:16px;opacity:.9;flex:0 0 auto}
  #dualToggle.on,#detailsToggle.on{background:color-mix(in srgb,var(--accent) 22%,transparent)}

  /* ── per-OS skins — the same model, the host's native chrome ────────────────────────── */
  html[data-os="macos"], html[data-os="ios"], html[data-os="ipados"]{ --r:9px }
