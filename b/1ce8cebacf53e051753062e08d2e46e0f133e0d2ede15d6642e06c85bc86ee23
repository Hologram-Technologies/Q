  html += `<div class="sgroup holohdr" id="holohdr"><span class="hchev ${holoOpen?'open':''}">${I.chev}</span>Hologram</div>`;
  if(holoOpen) html += HOLO_GROUP().map(l=> item(l, l.name, l.glyph||"drive", 'style="opacity:.9"')).join("");
  side.innerHTML = html;
  $$("#side .sitem[data-si]").forEach(el=>{ const n=_sideNodes[+el.dataset.si]; el.onclick=()=> openLocation(n); });
  $$("#side .tagitem").forEach(el=> el.onclick = ()=> filterByTag(el.dataset.tag));
  const hh=$("#holohdr"); if(hh) hh.onclick=()=>{ holoOpen=!holoOpen; localStorage.setItem("holo.files.holoOpen",holoOpen?"1":"0"); renderSide(); };
  markSide();
}
function markSide(){ const cur = trail[0]; $$("#side .sitem[data-si]").forEach(el=>{ const n=_sideNodes[+el.dataset.si]; el.classList.toggle("on", !!(cur && n && n.source===cur.source && n.path===cur.path)); }); }

/* ── navigation ─────────────────────────────────────────────────────────────────────── */
function openLocation(loc, push=true){ if(push) pushHist(); trail = [loc]; sel=null; selSet.clear(); anchorIdx=-1; render(); }
async function drillInto(n, push=true){
  if(n.source==="trash"){ await HoloFiles.restoreTrash(n); listCache.clear(); render(); toast("Restored "+n.name); return; }   // opening a bin item restores it
  if(n.kind==="file"){ select(n); return; }
  // NATIVE MIRROR (N1): real-folder affordances. Connect = the platform's own picker; a mount that
  // lost its grant re-arms with this tap (the click IS the required user gesture); the note is honest.
  if(n.source==="mount-connect"){ try{ const id=await HoloFiles.deviceMounts.mountPick(); if(id){ listCache.clear(); render(); toast("Connected"); } }catch(e){ toast("Couldn't connect: "+(e.message||e)); } return; }
  if(n.source==="import-connect"){   // the UNIVERSAL rung: the platform's own folder chooser, every browser
    let inp=$("#impdir");
    if(!inp){ inp=document.createElement("input"); inp.type="file"; inp.id="impdir"; inp.style.display="none"; inp.setAttribute("webkitdirectory",""); inp.setAttribute("directory",""); inp.multiple=true; document.body.appendChild(inp); }
    inp.onchange=()=>{ try{
      const r=HoloFiles.importFolder(inp.files); inp.value="";
      if(!r){ toast("Nothing to open"); return; }
      listCache.clear();
      openLocation({name:r.name,path:r.path,kind:"dir",source:"import-dir",id:"imp-"+r.id},false);
      toast(`Opened ${r.name} · ${r.count} file${r.count===1?"":"s"}`);
    }catch(e){ toast("Couldn't open: "+(e.message||e)); } };
    inp.click(); return;
  }
  if(n.source==="mount-dir" && n._mountState && n._mountState!=="granted"){
    const st=await HoloFiles.deviceMounts.remount(String(n.path).slice(6).split("/")[0]);
    if(st!=="granted"){ toast("This folder needs permission to open"); return; }
    listCache.clear();
  }
  if(push) pushHist();
  trail = [...trail, n]; sel=null; selSet.clear(); anchorIdx=-1; render();
}
function crumbTo(i){ pushHist(); trail = trail.slice(0, i+1); sel=null; selSet.clear(); anchorIdx=-1; render(); }
function up(){ if(trail.length>1){ pushHist(); trail.pop(); sel=null; selSet.clear(); anchorIdx=-1; render(); } }
function pushHist(){ histBack.push(trail.slice()); histFwd.length=0; }
function back(){ if(!histBack.length) return; histFwd.push(trail.slice()); trail = histBack.pop(); sel=null; selSet.clear(); anchorIdx=-1; render(); }
function fwd(){ if(!histFwd.length) return; histBack.push(trail.slice()); trail = histFwd.pop(); sel=null; selSet.clear(); anchorIdx=-1; render(); }

const cur = () => trail[trail.length-1];
const isHome = () => trail.length===0;

/* ── render ─────────────────────────────────────────────────────────────────────────── */
async function render(){
  if(searchMode){ searchMode=false; const q=$("#q"); if(q && q.value) q.value=""; }   // navigating exits search
  thumbReset();   // drop the previous listing's pending thumbnail loads (the κ cache itself persists for dedup)
  if(tabs[activeTab]) tabs[activeTab].trail=trail; renderTabs();                       // keep the active tab label live
  $("#back").disabled = !histBack.length; $("#fwd").disabled = !histFwd.length; $("#up").disabled = trail.length<=1;
  markSide(); renderCrumbs();
  const list = $("#list");
  if(isHome()){ renderHome(); $("#newfolder").style.display="none"; setStatus(); return; }
  const node = cur();
  $("#newfolder").style.display = (node.source==="opfs"||node.source==="desktop"||node.source==="device-dir") ? "" : "none";
  $("#emptybin").style.display = (node.source==="trash") ? "" : "none";
  list.innerHTML = `<div class="empty">Loading…</div>`;
  let kids; try{ kids = await childrenOf(node); }catch(e){ list.innerHTML = `<div class="empty">Couldn't read this location.<div style="color:var(--faint);font:var(--holo-text-sm, 1rem) var(--mono)">${(e.message||e)}</div></div>`; return; }
  items = sortItems(applyFilter(kids));
