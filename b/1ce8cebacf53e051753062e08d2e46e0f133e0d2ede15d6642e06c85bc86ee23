  for(const r of devRows) if(r.source==="mount-dir"||r.source==="import-dir") tiles.push({n:r,name:r.name,glyph:"folder",sub:tsub(r.source)});
  const PG={Desktop:"desktop",Documents:"documents",Downloads:"downloads",Pictures:"image",Music:"audio",Videos:"video"};
  if(!tiles.length) for(const d of Object.keys(PG)) tiles.push({n:{name:d,path:"/home/user/"+d,kind:"dir",source:"opfs",writable:true},name:d,glyph:PG[d],sub:"Hologram"});
  const door=devRows.find(r=>r.kind==="connect");
