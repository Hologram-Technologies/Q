function newTab(loc){ snapshotTab(); tabs.push(makeTab(loc)); activeTab=tabs.length-1; applyTab(); searchMode=false; const q=$("#q"); if(q) q.value=""; render(); }
function closeTab(i){ if(tabs.length<=1) return; snapshotTab(); tabs.splice(i,1); if(activeTab>i) activeTab--; else if(activeTab===i) activeTab=Math.min(i,tabs.length-1); applyTab(); render(); }
