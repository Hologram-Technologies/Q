// EDITABLE ADDRESS BAR — click the breadcrumb (or Ctrl/⌘+L) → an input of the current path; Enter jumps
// anywhere on the device (Files/Explorer parity). Esc/blur reverts.
function enterAddressEdit(){
  const c=$("#crumbs"); const curAbs=(cur()&&cur()._absPath)||"";
  c.innerHTML=`<input id="addr" class="addrinput" spellcheck="false" autocomplete="off" placeholder="Type a path, e.g. C:\\Users" value="${esc(curAbs)}">`;
  const inp=$("#addr"); inp.focus(); inp.select();
  inp.addEventListener("keydown",(e)=>{ e.stopPropagation(); if(e.key==="Enter"){ const v=inp.value; renderCrumbs(); navigateToPath(v); } else if(e.key==="Escape"){ renderCrumbs(); } });
  inp.addEventListener("blur",()=> setTimeout(()=>{ if(document.activeElement!==inp) renderCrumbs(); },120));
}
function navigateToPath(raw){
  let p=String(raw||"").trim().replace(/\\/g,"/").replace(/(.)\/+$/,"$1"); if(!p) return;
  if(!(/^[A-Za-z]:/.test(p) || p.startsWith("/"))){ toast("Enter a folder path, e.g. C:\\Users"); return; }
  const name=p.split("/").pop()||p;
  pushHist(); trail=[{ id:"dev:"+p, name, path:"device:"+p, kind:"dir", source:"device-dir", _absPath:p }];
  sel=null; selSet.clear(); anchorIdx=-1; render();
}

function renderListing(){
  const list = $("#list");
  if(!items.length){ list.innerHTML = emptyState(); wireEmpty(); return; }
  const groups = groupsOf();
  if(view==="details") list.innerHTML = tableView(groups);
  else if(view==="list") list.innerHTML = groups.map(g=>(g.key?`<div class="grouphdr">${esc(g.key)}<small>${g.idxs.length}</small></div>`:"")+`<div class="listv">`+g.idxs.map(i=>rowList(items[i],i)).join("")+`</div>`).join("");
  else list.innerHTML = `<div class="grid ${view==="tiles"?"tiles":"icons"}">`+items.map((n,i)=>cellView(n,i,view)).join("")+`</div>`;
  wireRows();
  wireThumbs();        // grid/tiles: lazily swap image glyphs for κ-keyed thumbnails (no-op for other views)
}
// Native columns per OS — NO content-address column (κ is the invisible engine). Date from /device/ls mtime.
const COLSPEC = {
  windows:[["name","Name"],["mtime","Date modified"],["kind","Type"],["bytes","Size"]],
  macos:[["name","Name"],["mtime","Date Modified"],["bytes","Size"],["kind","Kind"]],
  ios:[["name","Name"],["mtime","Date Modified"],["bytes","Size"],["kind","Kind"]],
  ipados:[["name","Name"],["mtime","Date Modified"],["bytes","Size"],["kind","Kind"]],
  linux:[["name","Name"],["bytes","Size"],["kind","Type"],["mtime","Modified"]],
};
const cols = () => COLSPEC[P.os] || COLSPEC.windows;
const fmtDate = (s)=>{ if(!s) return ""; try{ return new Date(s*1000).toLocaleString(undefined,{year:"numeric",month:"short",day:"numeric",hour:"2-digit",minute:"2-digit"}); }catch{ return ""; } };
const cellFor = (n,k)=> k==="name" ? `<div class="nm"><span class="gl" style="color:${tint(n)}">${glyphFor(n)}</span><span class="t">${esc(n.name)}</span>${tagDots(n)}</div>`
  : k==="mtime" ? fmtDate(n.mtime) : k==="kind" ? typeLabel(n) : k==="bytes" ? (n.bytes!=null?fmtBytes(n.bytes):"") : "";
function tableView(groups){
  const C=cols();
  const h = (k,l)=>`<th data-k="${k}">${l}${sortKey===k?(sortDir>0?" ▲":" ▼"):""}</th>`;
  let body="";
  for(const g of groups){
    if(g.key) body += `<tr class="grouphdr"><td colspan="${C.length}">${esc(g.key)}<small>${g.idxs.length}</small></td></tr>`;
    body += g.idxs.map(i=>{ const n=items[i]; return `<tr data-i="${i}" class="${sel&&sel.id===n.id?'sel':''}">`+
      C.map(([k])=>`<td${k==="name"?"":' style="color:var(--dim)"'}>${cellFor(n,k)}</td>`).join("")+`</tr>`; }).join("");
  }
  return `<table class="det"><thead><tr>${C.map(([k,l])=>h(k,l)).join("")}</tr></thead><tbody>${body}</tbody></table>`;
}
const rowList = (n,i)=>`<div class="lrow ${sel&&sel.id===n.id?'sel':''}" data-i="${i}"><span class="gl" style="width:18px;height:18px;color:${tint(n)}">${glyphFor(n)}</span><span class="t">${esc(n.name)}</span>${tagDots(n)}<span class="meta">${n.did?kshort(n.did):(n.role||"")} ${n.bytes!=null?'· '+fmtBytes(n.bytes):''}</span></div>`;
// an image cell carries data-thumb=<idx> so the lazy thumbnailer can swap its glyph for a κ-keyed <img>.
const thumbAttr = (n,i)=> (n.kind==="file" && ["image","video"].includes(kindOf(n.name))) ? ` data-thumb="${i}"` : "";
// folders on the device peek at the media inside them (Explorer/Finder-style live folder thumbnails)
const peekAttr = (n,i)=> (n.kind==="dir" && n.source==="device-dir") ? ` data-peek="${i}"` : "";
// poster frame for a video (no dep): decode bytes in a <video>, seek to the midpoint, draw to a canvas.
function videoPoster(bytes, mime){
  return new Promise((res)=>{
    const src=URL.createObjectURL(new Blob([bytes],{type:mime})); const v=document.createElement("video");
    v.muted=true; v.preload="auto"; v.src=src; let done=false;
    const fin=(out)=>{ if(done) return; done=true; try{URL.revokeObjectURL(src);}catch{} res(out); };
    v.onloadeddata=()=>{ try{ v.currentTime=Math.min(1,(v.duration||2)/2); }catch{ fin(null); } };
    v.onseeked=()=>{ try{ const w=200,h=Math.max(1,Math.round(w*(v.videoHeight||112)/(v.videoWidth||200)));
      const c=document.createElement("canvas"); c.width=w; c.height=h; c.getContext("2d").drawImage(v,0,0,w,h);
      c.toBlob(b=> fin(b?URL.createObjectURL(b):null), "image/jpeg", 0.82); }catch{ fin(null); } };
    v.onerror=()=>fin(null); setTimeout(()=>fin(null), 5000);
  });
}
const cellView = (n,i,v)=> v==="tiles"
  ? `<div class="cell sel-${sel&&sel.id===n.id} ${sel&&sel.id===n.id?'sel':''}" data-i="${i}"><span class="gl"${thumbAttr(n,i)}${peekAttr(n,i)} style="color:${tint(n)}">${glyphFor(n)}</span><div class="ct"><div class="cn">${esc(n.name)}</div><div class="csub">${n.did?kshort(n.did):typeLabel(n)}</div></div></div>`
  : `<div class="cell ${sel&&sel.id===n.id?'sel':''}" data-i="${i}"><span class="gl"${thumbAttr(n,i)}${peekAttr(n,i)} style="color:${tint(n)}">${glyphFor(n)}</span><div class="cn">${esc(n.name)}${tagDots(n)}</div></div>`;

/* ── κ-keyed lazy thumbnails (grid/tiles) ─────────────────────────────────────────────────
   A thumbnail is addressed by the file's CONTENT κ, so identical bytes (across paths, volumes,
   duplicates) render ONCE and share — the substrate magic. Only image cells scrolled into view
   load (IntersectionObserver), concurrency-capped; reading a device image's bytes lazily κ-stamps
   it at the host as a side effect. No thumbnail service, no extra store — just the κ-store. */
const THUMB = new Map();                       // κ-hex | "p:<path>" → objectURL (LRU-capped)
const THUMB_INFLIGHT = new Map();              // key → Promise<url|null> — concurrent loads of one κ share ONE read+URL
const THUMB_MAX = 360;
const thumbKey = (n)=> n.did ? String(n.did).split(":").pop() : ("p:"+(n.path||n.name));
let thumbObs = null, thumbInflight = 0; const thumbQ = [];
function thumbReset(){ if(thumbObs){ thumbObs.disconnect(); thumbObs=null; } thumbQ.length=0; }
function thumbCachePut(key,url){ THUMB.set(key,url); if(THUMB.size>THUMB_MAX){ const old=THUMB.keys().next().value, u=THUMB.get(old); THUMB.delete(old); try{ URL.revokeObjectURL(u); }catch{} } }
function thumbPump(){ while(thumbInflight<4 && thumbQ.length){ const job=thumbQ.shift(); thumbInflight++; job().finally(()=>{ thumbInflight--; thumbPump(); }); } }
// a node's κ-thumbnail URL (image bytes / video poster), cached by content κ + dedup'd. null = no thumb.
async function thumbURLFor(n){
  const kind=kindOf(n.name); if(!n._absPath && n.source!=="closure" || !["image","video"].includes(kind)) return null;
  const key=thumbKey(n); const have=THUMB.get(key); if(have) return have;
  const cap = kind==="video" ? 64*1024*1024 : 8*1024*1024;
  if(n.bytes!=null && n.bytes>cap) return null;
  let pend=THUMB_INFLIGHT.get(key);                                   // identical κ already loading → reuse it (true dedup)
  if(!pend){
    pend=(async()=>{ try{
      const {bytes,mime}=await HoloFiles.read(n, cap);
      if(kind==="image" && /^image\//.test(mime||"")){ const u=URL.createObjectURL(new Blob([bytes],{type:mime})); thumbCachePut(key,u); return u; }
      if(kind==="video"){ const u=await videoPoster(bytes, mime||"video/mp4"); if(u) thumbCachePut(key,u); return u; }
      return null;
    }catch{ return null; } finally { THUMB_INFLIGHT.delete(key); } })();
    THUMB_INFLIGHT.set(key,pend);
  }
  return await pend;
}
async function loadThumb(i, gl){
  const n=items[i]; if(!n) return;
  const url=await thumbURLFor(n);
  if(url && gl.isConnected && gl.dataset.thumb===String(i)) gl.innerHTML=`<img class="thumb" src="${url}" alt="">${kindOf(n.name)==="video"?'<span class="vbadge">'+I.video+'</span>':''}`;
}
// FOLDER PEEK — a folder shows a live mosaic of the media it contains (κ-thumbnails of up to 4 children),
// exactly like Explorer/Finder. One readdir (cached) + the shared thumbnailer; no media inside → stays a folder.
async function loadFolderPeek(i, gl){
  const n=items[i]; if(!n || n.kind!=="dir") return;
  let kids; try{ kids=await childrenOf(n); }catch{ return; }
  const media=kids.filter(k=>k.kind==="file" && ["image","video"].includes(kindOf(k.name))).slice(0,4);
  if(!media.length) return;                                            // no media → keep the native folder glyph
  const urls=(await Promise.all(media.map(thumbURLFor))).filter(Boolean);
  if(!urls.length || !gl.isConnected || gl.dataset.peek!==String(i)) return;
  gl.innerHTML=`<span class="peek peek-${urls.length}">`+urls.map(u=>`<img src="${u}" alt="">`).join("")+`</span>`;
}
function wireThumbs(){
  thumbReset();
  const gls=$$("#list .gl[data-thumb], #list .gl[data-peek]"); if(!gls.length) return;
  thumbObs=new IntersectionObserver((ents)=>{ for(const en of ents){ if(en.isIntersecting){ const gl=en.target; thumbObs.unobserve(gl);
    if(gl.dataset.thumb!=null) thumbQ.push(()=>loadThumb(+gl.dataset.thumb, gl));
    else if(gl.dataset.peek!=null) thumbQ.push(()=>loadFolderPeek(+gl.dataset.peek, gl));
    thumbPump(); } } }, { root:$("#list"), rootMargin:"240px" });
  gls.forEach(gl=> thumbObs.observe(gl));
}

async function renderColumns(){
  const list = $("#list");
  // build a column per trail level by listing each level's children, highlighting the next-in-trail
  const cols = [];
  for(let i=0;i<trail.length;i++){
    let kids=[]; try{ kids = await childrenOf(trail[i]); }catch{}
    kids = sortItems(kids);
    const nextSel = trail[i+1];
    cols.push(`<div class="col" data-level="${i}">`+kids.map((n,j)=>{
      const on = nextSel && nextSel.id===n.id || (sel && i===trail.length-1 && sel.id===n.id);
      return `<div class="lrow ${on?'sel':''}" data-level="${i}" data-name="${esc(n.name)}"><span class="gl" style="width:16px;height:16px;color:${tint(n)}">${glyphFor(n)}</span><span class="t">${esc(n.name)}</span>${(n.kind==='dir'||n.kind==='app')?`<span class="chev">${I.chev}</span>`:""}</div>`;
    }).join("")+`</div>`);
    columnCache[i]=kids;
  }
  list.innerHTML = `<div class="cols">`+cols.join("")+`</div>`;
  $$(".cols .col").forEach(col=>{ const lvl=+col.dataset.level; $$(".lrow",col).forEach((r,j)=>{ r.onclick=()=>{ const n=columnCache[lvl][j]; trail=trail.slice(0,lvl+1); if(n.kind==='dir'||n.kind==='app') drillInto(n,true); else { trail=trail.slice(0,lvl+1); select(n);} }; }); });
  const c = list.querySelector(".cols"); if(c) c.scrollLeft = c.scrollWidth;
}
const columnCache = {};

function wireRows(){
  $$("#list [data-i]").forEach(el=>{
    const n = items[+el.dataset.i];
    el.onclick = (e)=>{ select(n, e); };
    el.ondblclick = ()=>{ (n.kind==="dir"||n.kind==="app") ? drillInto(n) : openFile(n); };
    el.oncontextmenu = (e)=>{ e.preventDefault(); if(!selSet.has(n.id)) select(n); openCtx(e, n); };
    // HOVER-TO-PLAY: in grid/tiles, hovering a video plays a muted silent loop in place — the grid feels alive.
    if((view==="grid"||view==="tiles") && n.kind==="file" && kindOf(n.name)==="video"){
      const gl=el.querySelector(".gl"); let hv=null, ht=null;
      el.addEventListener("mouseenter",()=>{ ht=setTimeout(async()=>{ if(!gl||hv) return; const u=await mediaURL(n); if(!u||!gl.isConnected) return; hv=document.createElement("video"); hv.className="hoverplay"; hv.muted=true; hv.loop=true; hv.autoplay=true; hv.playsInline=true; hv.src=u; gl.appendChild(hv); try{ await hv.play(); }catch{} }, 240); });
      el.addEventListener("mouseleave",()=>{ clearTimeout(ht); if(hv){ try{hv.pause();}catch{} hv.remove(); hv=null; } });
    }
    // drag-and-drop: every FILE drags OUT carrying its holo://κ (paste anywhere) + the real bytes
    // (drop onto the desktop / another app). Home files are also internal-move sources; Home folders
    // accept drops (move). A κ link dropped IN materializes (handled on #main).
    if(n.kind==="file" || n.source==="opfs"){
      el.setAttribute("draggable","true");
      el.addEventListener("dragstart",(e)=>{
        dragSrc = (selSet.has(n.id)&&selSet.size>1) ? selectedNodes() : [n]; dragFromPane="a";
        el.classList.add("dragging");
        try{
          const link = holoLinkOf(n);                                  // holo://<hex> — sync if the κ is known/prewarmed
          if(link){ e.dataTransfer.setData("text/uri-list", link+"\r\n"); e.dataTransfer.setData("text/plain", link); }
          const warm = dragBlobs.get(n.id);                            // the real bytes → a droppable file on the OS
          if(warm) e.dataTransfer.setData("DownloadURL", `${warm.mime}:${n.name}:${warm.url}`);
          e.dataTransfer.effectAllowed = "copyMove";
        }catch{}
      });
      el.addEventListener("dragend",()=>{ el.classList.remove("dragging"); dragSrc=null; dragFromPane=null; $$(".dropok").forEach(x=>x.classList.remove("dropok")); });
      if((n.source==="opfs" || n.source==="desktop") && n.kind==="dir"){
        el.addEventListener("dragover",(e)=>{ if(dragSrc){ e.preventDefault(); e.stopPropagation(); el.classList.add("dropok"); } });
        el.addEventListener("dragleave",()=> el.classList.remove("dropok"));
        el.addEventListener("drop", async (e)=>{ if(!dragSrc) return; e.preventDefault(); e.stopPropagation(); el.classList.remove("dropok"); const srcs=dragSrc; dragSrc=null;
          if(n.source==="desktop"){ srcs.filter(s=>s.source==="desktop").forEach(s=> HoloFiles.deskMove(s, n)); return; }   // desktop move → the shell applies (unification)
          await dropAcross(n.path, srcs); });
      }
    }
  });
  $$("table.det thead th[data-k]").forEach(th=> th.onclick = ()=>{ const k=th.dataset.k; if(sortKey===k) sortDir=-sortDir; else {sortKey=k;sortDir=1;} render(); });
}
function select(n, e){
  const idx = items.indexOf(n);
  if(e && (e.metaKey||e.ctrlKey)){                              // toggle one
    if(selSet.has(n.id)){ selSet.delete(n.id); if(sel&&sel.id===n.id) sel=lastSel(); }
    else { selSet.add(n.id); sel=n; }
    anchorIdx=idx;
  } else if(e && e.shiftKey && anchorIdx>=0){                   // range
    const a=Math.min(anchorIdx,idx), b=Math.max(anchorIdx,idx);
    selSet=new Set(items.slice(a,b+1).map(x=>x.id)); sel=n;
  } else { selSet=new Set([n.id]); anchorIdx=idx; sel=n; }      // single
  markSelection();
  if(sel){ document.body.classList.toggle("nodet",false); $("#details").classList.add("on"); renderDetails(sel); if(sel.kind==="file"){ prewarmDrag(sel); prefetchKappa(sel); } }
  setStatus();
}
function lastSel(){ let id=null; for(const x of selSet) id=x; return items.find(n=>n.id===id)||null; }
function markSelection(){ $$("#list [data-i]").forEach(el=>{ const it=items[+el.dataset.i]; el.classList.toggle("sel", !!(it && selSet.has(it.id))); }); }
function selectedNodes(){ return items.filter(n=>selSet.has(n.id)); }

/* ── drag-out-as-κ: a selected file is pre-warmed into a blob (the real bytes) + its holo://κ, so
   dragging it OUT lands a droppable file on the desktop AND a content-address link in any text field. */
const dragBlobs = new Map();          // node.id → { url, mime, link }
function holoLinkOf(n){ const w=dragBlobs.get(n.id); if(w&&w.link) return w.link; if(n.did) return "holo://"+String(n.did).split(":").pop(); return ""; }
async function prewarmDrag(n){
  if(!n || n.kind!=="file" || dragBlobs.has(n.id)) return;
  if(n.bytes!=null && n.bytes>32*1024*1024) return;          // cap pre-warm to keep selection snappy
  try{ const {bytes,mime}=await HoloFiles.read(n,32*1024*1024); const url=URL.createObjectURL(new Blob([bytes],{type:mime||"application/octet-stream"})); const hex=n.did?String(n.did).split(":").pop():await sha256hexLocal(bytes); dragBlobs.set(n.id,{ url, mime:mime||"application/octet-stream", link:"holo://"+hex }); }catch{}
}
// κ-on-glance: the moment a file is selected, content-address it (debounced, cancellable) so by the
// time you preview/open/share it, its κ is already known — every file you touch is already an object.
let _kappaT=null, _kappaFor=null;
function prefetchKappa(n){
  if(!n || n.did || n.source!=="closure" || !String(n.path).startsWith("device:")) return;
  _kappaFor=n; clearTimeout(_kappaT);
  _kappaT=setTimeout(async()=>{ if(_kappaFor!==n) return; try{ const did=await HoloFiles.ensureKappa(n); if(did && sel===n) renderDetails(n); }catch{} }, 220);
}

