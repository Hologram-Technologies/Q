async function runLocalSearch(){
  const q=$("#q").value.trim();
  if(!q){ searchMode=false; render(); return; }
  searchMode=true; $("#list").innerHTML=`<div class="empty">Searching…</div>`;
  let res=[]; try{ res=await HoloFiles.searchAll(q); }catch{}
  if($("#q").value.trim()!==q) return;                 // a newer keystroke won
  items=res; sel=null; renderSearchResults(q,res); setStatus();
}
async function runEnter(){
  const q=$("#q").value.trim(); if(!q) return;
  // Q-SOUL: plain words become PLANS (deterministic — a small grammar over the verbs you already
  // have; nothing waits on a model). "move these to Trip", "zip this", "new folder Photos",
  // "delete these", "keep one", "biggest" — each previews before it acts.
  const plan=parseIntent(q);
  if(plan){ $("#q").value=""; searchMode=false; render(); if(plan.answer) return plan.answer(); qPlanCard(plan); return; }
  let r=null; try{ r=await HoloFiles.resolveInput(q); }catch{}
  if(r && r.kind==="node"){ openLocation(LOCS[3]); $("#q").value=""; searchMode=false; setTimeout(()=>select(r.node),60); toast("Found "+r.node.name); return; }
  await runWebSearch(q);
}
/* ── Q-SOUL: intent grammar + the preview-before-power card ──────────────────────────────── */
function selPaths(){ return (selSet.size>1?selectedNodes():(sel?[sel]:[])).filter(n=>String(n.path).startsWith("/home/user/")).map(n=>n.path); }
function parseIntent(q){
  const s=q.trim();   // regexes match case-insensitively; captures keep the user's own casing
  const here=cur(); const home=(here&&here.source==="opfs")?here.path:"/home/user";
  let m;
  if((m=s.match(/^(?:move|put) (?:this|these|it|them)?\s*(?:in|into|to)\s+(.+)$/i))){ const t=selPaths(); if(t.length) return {verb:"move",targets:t,dest:home,name:m[1].trim()}; }
  if((m=s.match(/^(?:tidy|organi[sz]e)(?: these| this)?(?: into (.+))?$/i))){
    const t=selPaths();
    if(t.length) return {verb:"move",targets:t,dest:home,name:(m[1]||"Tidy").trim()};
    // nothing selected → tidy the WHOLE folder by month (each file's own date)
    const loose=items.filter(n=>n.kind==="file"&&String(n.path).startsWith("/home/user/"));
    if(loose.length>1&&!m[1]){ const mt={}; for(const n of loose) mt[n.path]=(n.mtime||0)*1000; return {verb:"tidyMonths",targets:loose.map(x=>x.path),dest:home,mtimes:mt}; }
  }
  if((m=s.match(/^(?:new folder|create folder|make (?:a )?folder)(?: called| named)?\s+(.+)$/i))) return {verb:"newFolder",dest:home,name:m[1].trim()};
  if(/^zip(?: these| this| them)?$/i.test(s)){ const t=selPaths(); if(t.length) return {verb:"zip",targets:t}; }
  if(/^(?:delete|trash|remove)(?: these| this| them)?$/i.test(s)){ const t=selPaths(); if(t.length) return {verb:"trash",targets:t}; }
