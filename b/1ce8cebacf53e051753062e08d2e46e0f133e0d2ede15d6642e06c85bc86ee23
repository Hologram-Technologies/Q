// minimal ZIP central-directory parser — names + uncompressed sizes, no extraction, no deps.
function parseZipCentral(u8){
  const n=u8.length; if(n<22) return null;
  const ed=new DataView(u8.buffer,u8.byteOffset,u8.byteLength); const dec=new TextDecoder();
  let eocd=-1; for(let i=n-22;i>=Math.max(0,n-65557);i--){ if(u8[i]===0x50&&u8[i+1]===0x4b&&u8[i+2]===0x05&&u8[i+3]===0x06){ eocd=i; break; } }
  if(eocd<0) return null;
  const count=ed.getUint16(eocd+10,true); let off=ed.getUint32(eocd+16,true); const out=[];
  for(let i=0;i<count && off+46<=n;i++){
    if(!(u8[off]===0x50&&u8[off+1]===0x4b&&u8[off+2]===0x01&&u8[off+3]===0x02)) break;
    const size=ed.getUint32(off+24,true), nlen=ed.getUint16(off+28,true), elen=ed.getUint16(off+30,true), clen=ed.getUint16(off+32,true);
    const name=dec.decode(u8.slice(off+46,off+46+nlen));
    out.push({ name, size, dir:name.endsWith("/") });
    off+=46+nlen+elen+clen;
  }
