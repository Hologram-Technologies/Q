const tagDots=(n)=>{ const t=tagsOf(n); return t.length?`<span class="tagdots">${t.slice(0,4).map(id=>`<i class="td" style="background:${(TAGMAP[id]||{}).color||'#888'}"></i>`).join("")}</span>`:""; };
