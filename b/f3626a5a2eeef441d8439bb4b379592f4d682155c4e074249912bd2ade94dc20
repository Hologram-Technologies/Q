.hdots{position:absolute;right:var(--s4);bottom:var(--s3);display:flex;gap:var(--s2)}
.hdot{width:8px;height:8px;border-radius:50%;background:#ffffff2b;transition:.2s}
.hdot.on{background:#fff;box-shadow:0 0 8px #fff8}
/* holographic cards */
.card{position:relative;background:var(--panel);border:1px solid var(--line);border-radius:var(--s3);padding:var(--s4);cursor:pointer;
  display:flex;flex-direction:column;gap:var(--s3);transition:border-color .2s,box-shadow .2s,transform .12s;transform:perspective(800px)}
.card::before{content:'';position:absolute;inset:0;border-radius:inherit;pointer-events:none;opacity:0;transition:opacity .25s;
  background:radial-gradient(233px circle at var(--mx,50%) var(--my,0%),#ffffff12,transparent 62%)}
.card:hover{border-color:color-mix(in srgb,var(--tint,#7aa5f8) 50%,var(--line2));
  box-shadow:0 13px 34px #000a,0 0 34px color-mix(in srgb,var(--tint,#7aa5f8) 13%,transparent)}
.card:hover::before{opacity:1}
.chead{display:flex;gap:var(--s3);align-items:center;min-width:0}
.ic{width:var(--s6);height:var(--s6);flex:0 0 auto;display:flex;align-items:center;justify-content:center;background:#fff;border-radius:var(--s3);padding:var(--s2);font-size:26px;overflow:hidden}
.ic img{width:100%;height:100%;object-fit:contain}
.meta{min-width:0;display:flex;flex-direction:column;gap:2px}
.nm{font-weight:650;font-size:15px;letter-spacing:-.1px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--tx)}
