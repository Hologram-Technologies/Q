function query(){ const q=curQ.toLowerCase();
  let list=CAT.images.filter(a=>{
    if(curTier==='stream' && !STREAMABLE(a)) return false;                                         // "how it opens" facet
    if(curTier==='open' && a.tier!=='V') return false;
