  background:var(--bg);color:var(--tx);-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility;font-optical-sizing:auto}
.nm,.hname,.htitle,.bt,button{font-family:"Segoe UI Variable Display","Segoe UI Variable Text","Segoe UI",ui-sans-serif,system-ui,sans-serif}
.foot,.hstats,#count,.kv,.pub{font-variant-numeric:tabular-nums}
a{color:var(--blue)} .hint{color:var(--tx3);font-size:13px} .mut{color:var(--tx3)}
::selection{background:#7aa5f855}
header{position:sticky;top:0;z-index:5;height:var(--s6);padding:0 var(--s5);border-bottom:1px solid var(--line);background:#0a0d14e8;backdrop-filter:blur(13px);display:flex;gap:var(--s4);align-items:center}
.brand{display:flex;gap:var(--s3);align-items:center;cursor:pointer;flex:0 0 auto}
.hlogo{position:relative;width:var(--s5);height:var(--s5);border-radius:var(--s2);display:flex;align-items:center;justify-content:center;
  background:#0d1119;border:1px solid #28304a;overflow:hidden;box-shadow:0 0 21px #7a8df626}
.hlogo img{width:26px;height:26px;display:block}
.hlogo::after{content:'';position:absolute;inset:-40%;background:linear-gradient(115deg,transparent 43%,#ffffff2b 50%,transparent 57%);
  transform:translateX(-100%);animation:sheen 5.5s ease-in-out infinite}
@keyframes sheen{0%,62%{transform:translateX(-100%)}88%,100%{transform:translateX(100%)}}
.bt{font-weight:700;font-size:16px;letter-spacing:.1px}
