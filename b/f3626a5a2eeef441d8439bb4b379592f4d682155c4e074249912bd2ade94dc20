#image{width:233px} #cmd{width:190px} #port{width:76px}
button{background:var(--blue);color:#0a0d14;border:0;border-radius:var(--s3);padding:var(--s2) var(--s4);font:inherit;font-weight:700;cursor:pointer;transition:filter .15s}
button:hover{filter:brightness(1.1)}
button.ghost{background:var(--panel2);color:var(--tx)}
button.big{padding:var(--s3) var(--s5);font-size:16px;border-radius:var(--s3)}
