$('#mList').onclick=()=>{ MODE='list'; $('#mList').classList.add('on'); $('#mGrid').classList.remove('on'); refresh(); };
$('#mGrid').onclick=()=>{ MODE='grid'; $('#mGrid').classList.add('on'); $('#mList').classList.remove('on'); refresh(); };
function maybeMore(){ if(SHOWN<view.length && $('#browse').style.display!=='none'){ const gw=$('.gridwrap'); if(gw.scrollTop+gw.clientHeight>gw.scrollHeight-987) page(); } }
new IntersectionObserver(es=>{ if(es[0].isIntersecting) maybeMore(); },{root:$('.gridwrap'),rootMargin:'610px'}).observe($('#sentinel'));
$('.gridwrap').addEventListener('scroll',maybeMore,{passive:true});
let deb; $('#search').addEventListener('input',()=>{ clearTimeout(deb); deb=setTimeout(()=>{ const v=$('#search').value.trim(); if(v!==curQ){ curQ=v; refresh(); } },140); });
$('#sort').addEventListener('change',refresh);
// spotlight
let hIdx=0,hTimer=null,HERO=[];
function heroPaint(i){ const a=HERO[i]; if(!a) return; hIdx=i;
  $('#hero .hbg').style.backgroundImage='url("'+a.art+'")'; $('#hic2').innerHTML=logoEl(a);
  $('#hname').textContent=a.name; $('#hpub').innerHTML=pubLine(a); $('#hdesc').textContent=a.why;
  $('#hstats').innerHTML=(a.pulls?'<span>'+I.dl+esc(a.pulls)+'</span>':'')+'<span>'+I.star+fmtN(a.stars)+'</span>'+(a.updated?'<span>'+I.clock+ago(a.updated)+'</span>':'');
  document.querySelectorAll('.hdot').forEach((d,k)=>d.classList.toggle('on',k===i)); }
function heroShow(i){ const inner=$('#hinner'); if(!inner) return heroPaint(i); inner.classList.add('swap'); setTimeout(()=>{ heroPaint(i); inner.classList.remove('swap'); },300); }
function heroSpin(){ clearInterval(hTimer); hTimer=setInterval(()=>{ if(!document.hidden && $('#browse').style.display!=='none') heroShow((hIdx+1)%HERO.length); },6000); }
function heroBuild(list){ const h=$('#hero'); HERO=list.filter(a=>a.art&&a.why).slice(0,5);
  if(HERO.length<3){ h.classList.remove('on'); clearInterval(hTimer); return; }
  h.innerHTML='<div class=hbg></div><div class=hgrad></div><div class=hinner id=hinner><div class=hic2 id=hic2></div>'+
    '<div style="flex:1;min-width:0"><div class=hkicker>Trending across the open web · streams here</div>'+
    '<div class=hname id=hname></div><div id=hpub></div><div class=hdesc id=hdesc></div><div class=hstats id=hstats></div></div>'+
    '<button class=big style="flex:0 0 auto">⚡ Stream</button></div>'+
    '<div class=hdots>'+HERO.map((_,k)=>'<span class="hdot'+(k===0?' on':'')+'"></span>').join('')+'</div>';
  h.classList.add('on'); h.onclick=()=>detail(HERO[hIdx]); h.onpointerenter=()=>clearInterval(hTimer); h.onpointerleave=heroSpin; heroPaint(0); heroSpin(); }
// runtime doors — every entry streams in the holospace runtime as a κ-addressable object, dispatched by kind:
//   docker  → holo-run prepares the image into the κ fabric → resumes in-tab (κ container pack)
//   repo    → the animate ladder compiles/boots the repo → a κ .holo, runs in-tab
const RUNTIME_NOTE={ stream:'Opens and runs right here — nothing to install, no account, no waiting. Just tap and it streams.',
  animate:'Opens right here in Hologram. The first time it takes a moment to get ready, then it streams instantly — for you and anyone you share it with.',
  web:'Streams live right here in your window — the whole app, with nothing to install and no sign-up.',
  view:'This one lives on its own site. Tap to open it there.' };
const doorOf=a=>(a.action&&a.action.door)||'stream';
// the animate app deep-link (a sibling app on the same origin) — ?run=<owner/repo> auto-runs it in-tab.
function animateURL(slug){ return '../tauri/animate-web/?run='+encodeURIComponent(slug); }
// image page
function detail(a){ curApp=a; show('detail'); const door=doorOf(a); const s=STREAMABLE(a);
  const btn = s?'⚡ Stream it':'↗ Open';
  const sub = a.site?esc(hostOf(a.site)) : esc(String(a.id||'').replace(/^[a-z]+:/,''));
  const also = (a.sources||[]).map(x=>SRCLABEL[x.src]||x.src);
  $('#detail').innerHTML=(a.art?'<div class=dback style="background-image:url(&quot;'+a.art+'&quot;)"></div>':'')+
   '<div class=dwrap><div class=hero><div class=hic>'+logoEl(a)+'</div>'+
     '<div style="flex:1;min-width:233px"><div class=htitle>'+esc(a.name)+' '+tierBadge(a)+'</div>'+pubLine(a)+
       '<div class=hwhy>'+esc(a.why)+'</div><div class=hint style="margin-top:8px">'+sub+'</div></div>'+
     '<button class=big id=stream>'+btn+'</button></div>'+
   '<div class=cols><div class=panel><h3>'+(s?'Runs right here':'Where to find it')+'</h3>'+
       '<p>'+(RUNTIME_NOTE[door]||RUNTIME_NOTE.stream)+'</p>'+
       (door==='web'&&a.framable===false?'<p class=mut>This one opens in the Hologram browser instead of inline — same app, its own window.</p>':'')+'</div>'+
     '<div class=panel><h3>About</h3><div class=kv>'+
       '<span class=k>Opens</span><span class=v>'+(s?'Right here':'Its own site')+'</span>'+
       (a.site?'<span class=k>Site</span><span class=v>'+esc(hostOf(a.site))+'</span>':'')+
       (a.pulls?'<span class=k>Downloads</span><span class=v>'+esc(a.pulls)+'</span>':'')+
       (a.stars?'<span class=k>Stars</span><span class=v>★ '+fmtN(a.stars)+'</span>':'')+
       (a.updated?'<span class=k>Updated</span><span class=v>'+ago(a.updated)+'</span>':'')+
       (also.length?'<span class=k>Found on</span><span class=v>'+esc(also.join(', '))+(a.buzz>1?' · trending':'')+'</span>':'')+
       (a.cats&&a.cats.length?'<span class=k>Category</span><span class=v>'+esc(a.cats.slice(0,3).join(', '))+'</span>':'')+
       '</div></div></div></div>';
  $('#stream').onclick=()=>launch(a);
  try{ if(RUNTIME!==null && door==='stream') fetch(base('/prewarm'),{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({image:a.image,port:'',cmd:''})}); }catch(_){}
}
// ── streaming via the holospaces runtime. A Hologram node (holo-serve, or an OS peer) prepares the
// image into the κ fabric; the tab then resumes it 100% in-browser on the vendored wasm. If no node
// is reachable from a pure-static deploy, we say so honestly rather than spin forever.
const RUNTIME = (window.HOLO_RUNTIME!==undefined ? window.HOLO_RUNTIME : ''); // '' = same origin; null = none
const base = p => (RUNTIME||'')+p;
function launch(a){ const d=doorOf(a); $('#ptitle').textContent=a.name||'';
  if(d==='animate') return launchAnimate(a);
  if(d==='view') return void window.open((a.sources&&a.sources[0]&&a.sources[0].url)||a.site||a.action.target,'_blank','noopener');
  if(d==='web') return launchWeb(a);
  show('portal'); $('#image').value=a.image; $('#port').value=''; $('#cmd').value=''; run(); }
function launchWeb(a){ const url=a.action.target||a.site;
  const holo=(()=>{ try{ return window.HoloResolve||(window.parent&&window.parent!==window&&window.parent.HoloResolve)||null; }catch(_){ return null; } })();
  if(holo){ try{ holo.open(url); return; }catch(_){} }
  show('portal'); if($('#image')) $('#image').value=url; runBtn.disabled=false; setStatus('Opening…'); LINES.length=0; logEl.textContent='';
  log('Opening '+(a.name||hostOf(url))+'…');
  frame.removeAttribute('srcdoc'); frame.src=url; let done=false;
  frame.onload=()=>{ done=true; setStatus('Streaming'); log('Streaming now — enjoy!','k'); };
  setTimeout(()=>{ if(!done) webBlocked(a,url); },3500); }
function webBlocked(a,url){ setStatus('Opens in its own window',true);
  log(a.name+' opens in its own window — same app.');
  frame.srcdoc='<body style="margin:0;display:grid;place-items:center;height:100vh;background:#0a0d14;color:#98a2bc;font:15px system-ui;text-align:center"><div><div style=font-size:34px>⚡</div><p style="font-size:15px"><b style="color:#e2e8f5">'+esc(a.name)+'</b> opens in its own window.</p><p><a href="'+esc(url)+'" target=_blank rel=noopener style=color:#7aa5f8>Open '+esc(hostOf(url))+' ↗</a></p></div></body>'; }
function launchAnimate(a){ show('portal'); $('#image').value=a.image; $('#port').value=''; $('#cmd').value=''; runBtn.disabled=false;
  setStatus('Getting it ready…'); LINES.length=0; logEl.textContent='';
  log('Getting '+(a.name||'it')+' ready…');
  frame.src=animateURL(a.action.target);
  frame.onload=()=>{ setStatus('Streaming'); log('Streaming now — enjoy!','k'); };
}
const LINES=[]; let seenSrv=0;
function stamp(){ const d=new Date(); return d.toTimeString().slice(0,8)+'.'+String(d.getMilliseconds()).padStart(3,'0'); }
function log(msg,cls){ LINES.push('['+stamp()+'] '+msg); const div=document.createElement('div');
  div.innerHTML='<span class=t>['+stamp()+']</span> <span'+(cls?(' class='+cls):'')+'>'+String(msg).replace(/</g,'&lt;')+'</span>';
  logEl.appendChild(div); logEl.scrollTop=logEl.scrollHeight; }
$('#copy').onclick=async()=>{ try{await navigator.clipboard.writeText(LINES.join('\n')); $('#copy').textContent='Copied!'; setTimeout(()=>$('#copy').textContent='Copy',1200);}catch(_){}};
$('#clear').onclick=()=>{ LINES.length=0; logEl.textContent=''; };
addEventListener('message',e=>{ const d=e.data; if(!d||d.ho===undefined) return;
  if(d.ho==='paint') log('First frame — streaming','k');
  else if(d.ho==='live') log('Ready — enjoy!','k');
  else if(d.ho==='error') log('Something went wrong: '+d.msg,'e'); });
async function run(){ const image=$('#image').value.trim(); if(!image)return;
  const port=$('#port').value.trim(), cmd=$('#cmd').value.trim();
  runBtn.disabled=true; frame.removeAttribute('src'); setStatus('Getting it ready…'); seenSrv=0;
  log('Getting '+((curApp&&curApp.name)||image)+' ready…');
  if(RUNTIME===null){ streamlessNote(image); return; }
  let r; try{ r=await fetch(base('/run'),{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({image,port,cmd})}); }
  catch(e){ return streamlessNote(image); }
  if(!r.ok){ return streamlessNote(image); }
  const j=await r.json(); if(j.error){ log('Couldn’t start it: '+j.error,'e'); setStatus('Something went wrong',true); runBtn.disabled=false; return; }
  const id=j.id; log('Setting things up…');
  const poll=setInterval(async()=>{ let s; try{ s=await (await fetch(base('/job/'+id))).json(); }catch(e){ return; }
    setStatus(s.status==='ready'?'Streaming':s.status==='error'?'Something went wrong':'Getting it ready…', s.status==='error');
    const srv=s.log||[]; for(;seenSrv<srv.length;seenSrv++){ const l=srv[seenSrv]; if(/error|fail|panic|refus/i.test(l)) log(l,'e'); else if(/cached|resumed|is live|published|ready/i.test(l)) log('Almost there…','k'); }
    if(s.status==='ready'){ clearInterval(poll); runBtn.disabled=false; setStatus('Streaming');
      const q=s.pack?('holo-app.html?pack='+encodeURIComponent(s.pack.pack)+'&mz='+encodeURIComponent(s.pack.manifestZ)+'&idx='+encodeURIComponent(s.pack.idx)+(s.pack.idxZ?('&idxz='+encodeURIComponent(s.pack.idxZ)):'')+(s.pack.lazy?'&lazy=1':'')+'&port='+(s.port||80)+(s.resp?('&resp='+encodeURIComponent(s.resp)):''))
                        :('holo-app.html?k='+encodeURIComponent(s.holo)+'&port='+(s.port||80)+(s.resp?('&resp='+encodeURIComponent(s.resp)):''));
      log('Ready — enjoy!','k'); frame.src=q; }
    if(s.status==='error'||s.status==='stopped'){ clearInterval(poll); runBtn.disabled=false; log('Stopped','e'); }
  },700);
}
function streamlessNote(image){ runBtn.disabled=false; setStatus('Opens on a Hologram device',true);
  log('Browsing works instantly right here. To stream this one, open it on a Hologram device.','p');
  frame.srcdoc='<body style="margin:0;display:grid;place-items:center;height:100vh;background:#0a0d14;color:#98a2bc;font:15px system-ui;text-align:center"><div><div style="font-size:34px">⚡</div><p style="font-size:15px"><b style="color:#e2e8f5">'+esc((curApp&&curApp.name)||image)+'</b> streams on a Hologram device.<br>Browsing and discovery work right here.</p></div></body>';
}
runBtn.onclick=run; $('#image').addEventListener('keydown',e=>{if(e.key==='Enter')run()});
show('browse'); boot();
