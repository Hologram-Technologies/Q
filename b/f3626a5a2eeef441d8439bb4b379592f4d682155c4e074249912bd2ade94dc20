.tabswrap::before{left:var(--s5);background:linear-gradient(90deg,var(--bg),transparent)}
.tabswrap::after{right:var(--s5);background:linear-gradient(270deg,var(--bg),transparent)}
.tabswrap.l::before{opacity:1} .tabswrap.r::after{opacity:1}
