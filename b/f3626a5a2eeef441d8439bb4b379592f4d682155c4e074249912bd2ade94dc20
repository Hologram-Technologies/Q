<!doctype html><html lang=en><head><meta charset=utf-8><meta name=viewport content="width=device-width,initial-scale=1">
<title>Holo Hub</title><link rel=icon href=hologram.svg><style>
/* ── golden-ratio system: Fibonacci spacing (5 8 13 21 34 55 89) + φ type scale (13 → 21 → 34) ── */
