select{background:var(--panel);border:1px solid var(--line2);color:var(--tx2);border-radius:var(--s3);padding:var(--s2) var(--s3);font:inherit;height:var(--s5);outline:none}
#status{color:var(--green)} #status.err{color:var(--red)}
/* category rail */
.tabswrap{position:relative;padding:var(--s4) var(--s5) 0;flex:0 0 auto}
.tabs{display:flex;gap:var(--s2);overflow-x:auto;scrollbar-width:none;scroll-behavior:smooth}
