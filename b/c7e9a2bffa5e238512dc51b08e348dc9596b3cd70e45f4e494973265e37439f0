/* HOLO-WA-TYPE-SCALE-2026-07-13 — WhatsApp type tokens + 11px legibility floor (mirrors canonical whatsapp-theme.css) */
.holo-wa-root {
  --wa-fs-title:16.5px;   /* chat-list conversation name */
  --wa-fs-header:16px;    /* conversation header name */
  --wa-fs-body:14.2px;    /* message bubble text (WA: 14.2px/19px) */
  --wa-fs-lh:19px;        /* message bubble line-height */
  --wa-fs-sub:13.8px;     /* chat-list last-message preview */
  --wa-fs-input:15px;     /* composer input */
  --wa-fs-meta:12.5px;    /* quotes, senders, secondary labels */
  --wa-fs-time:11px;      /* bubble timestamp + ticks */
  --wa-fs-min:11px;       /* absolute floor for readable text */
}
/* reading-critical selectors consume the tokens (numerically identical to the shipped look — no visual drift) */
.holo-wa-root .cs-conversation__name { font-size:var(--wa-fs-title); }
.holo-wa-root .cs-conversation__info { font-size:var(--wa-fs-sub); }
.holo-wa-root .cs-conversation-header__user-name { font-size:var(--wa-fs-header); }
.holo-wa-root .cs-message__content { font-size:var(--wa-fs-body); line-height:var(--wa-fs-lh); }
.holo-wa-root .holo-msg-time { font-size:var(--wa-fs-time); }
.holo-wa-root .holo-tick { font-size:var(--wa-fs-time); }
.holo-wa-root .holo-foot { font-size:var(--wa-fs-time); }
.holo-wa-root .holo-c-input { font-size:var(--wa-fs-input); }
.holo-wa-root .holo-quote { font-size:var(--wa-fs-meta); }
.holo-wa-root .holo-sender { font-size:var(--wa-fs-meta); }
/* legibility floor — real text never below 11px (glyph-only rules like locks/ticks/pins are exempt) */
.holo-wa-root .holo-profile-url { font-size:var(--wa-fs-min); }
.holo-money-foot { font-size:var(--wa-fs-min); }
.holo-kc-seal { font-size:var(--wa-fs-min); }
.holo-together-foot { font-size:var(--wa-fs-min); }
.holo-key-foot { font-size:var(--wa-fs-min); }
.holo-wa-root .holo-net-status { font-size:var(--wa-fs-min); }
.holo-wa-root .holo-cmd-meta { font-size:var(--wa-fs-min); }
.holo-cu-learned { font-size:var(--wa-fs-min); }
.holo-together-live { font-size:var(--wa-fs-min); }
.holo-key-livepill { font-size:var(--wa-fs-min); }
.holo-rail-badge { font-size:10.5px; }
