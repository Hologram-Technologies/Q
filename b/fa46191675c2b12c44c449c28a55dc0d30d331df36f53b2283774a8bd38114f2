<!-- the lock overlay + BASELINE first-paint (synchronous, dependency-free): paints a working "It's me"
     panel on the FIRST frame from a tiny local greeting cache (holo.lastOperator — the SAME hint the OS
     greeter writes), so a returning operator's name + button appear with zero identity/model load. The
     module below wires the real biometric; this only ever OWNS the frame until it lands. -->
<div id="holo-login"><div class="hl-wall"></div><div class="hl-frost"></div><main class="hl-lock"><div class="hl-panel" id="holo-login-panel"></div></main></div>

<!-- Machine-readable sign-in contract for AI agents — always in the DOM, even before scripts run, so an
     agent can discover guest access by parsing the page. Read by window.HoloLogin.options. Mirrors the OS
     greeter's #holo-agent-login. Guest = act now (no human); biometric = ask the person. -->
<script type="application/json" id="holo-agent-login">
{
  "service": "Holo Messenger sign-in",
  "audience": "ai-agent",
  "summary": "Two ways in. Guest is instant and needs no human; the biometric needs the person.",
  "options": [
    {
      "id": "guest",
      "title": "Guest",
      "persistent": false,
      "requiresHuman": false,
      "do": { "navigate": "?guest=1", "call": "window.HoloLogin.guest()" },
      "result": "An instant, private, ephemeral guest session into the Hologram system (Holo Messenger). No biometric and no human needed. Nothing persists after the session ends."
    },
    {
      "id": "biometric",
      "title": "It’s me",
      "persistent": true,
      "requiresHuman": true,
      "do": { "tap": "the 'It’s me' / 'Sign in' button", "then": "ask the person to approve with their device biometric (Windows Hello / Touch ID)" },
      "result": "Signs in with this device's TEE to the operator's sovereign identity (the SAME κ as the OS). An agent cannot complete this alone."
    }
  ]
}
</script>
<script>
(function () {
  try { if (navigator.storage && navigator.storage.persist) navigator.storage.persist().catch(function(){}); } catch (e) {}
  var panel = document.getElementById("holo-login-panel"); if (!panel) return;
  var esc = function (s) { return String(s).replace(/[&<>"]/g, function (c) { return ({ "&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;" }[c]); }); };
  var op = null; try { op = JSON.parse(localStorage.getItem("holo.lastOperator") || "null"); } catch (e) {}
  // Paint the SHARED wallpaper behind the lock at first frame (the same one the desktop + home wear), so the
  // sign-in is never a black void. A live-sim / none / plain falls back to the shipped default photo — the SAME
  // default the home shows — so login and home always match. κ → content route; a path/url passes through.
  try {
    // APPEARANCE at 0 ms — the lock wears the SAME holo.theme.v1 row home wears: immersive (wallpaper),
    // dark, or light. One data attribute flips the whole token set; flat modes never fetch the photo.
    var _thm = {}; try { _thm = JSON.parse(localStorage.getItem("holo.theme.v1") || "{}") || {}; } catch (e) {}
    var _mode = (_thm.immersive === false) ? (_thm.palette === "light" ? "light" : "dark") : "immersive";
    var _lv = document.getElementById("holo-login");
    if (_lv) _lv.setAttribute("data-appearance", _mode);
    var _tw = _thm.wallpaper || "";
    var _km = String(_tw).match(/^(sha256|blake3|sha512):([0-9a-f]+)$/i);
    var _wp = _km ? ("/.holo/" + _km[1].toLowerCase() + "/" + _km[2]) : ((!_tw || _tw === "plain" || /^live:/i.test(_tw)) ? "" : _tw);
    // MATCH THE HOME EXACTLY: the messenger home resolves its wallpaper as holo.theme.v1 → the messenger's own
    // "holo-messenger/wallpaper-src" pick → the shipped default. The lock skipped the middle step, so a wallpaper
    // set only via the messenger's picker showed on home but not here. Fold that same fallback in — one chain,
    // so the sign-in glass and the desktop it lifts onto are never two different photos.
    if (!_wp) { try { _wp = localStorage.getItem("holo-messenger/wallpaper-src") || ""; } catch (e) {} }
    if (!_wp) _wp = "./_vendor/wallpaper-default.jpg";
    var _wall = document.querySelector("#holo-login .hl-wall");
    if (_wall && _mode === "immersive") _wall.style.backgroundImage = 'url("' + _wp + '")';
    // PLYMOUTH BOOT SPLASH baseline (holo-plymouth.mjs owns the real player; this is the 0-ms frame). Once a
    // boot style has been worn (holo.plymouth.v1 persisted), a cold open paints a dedicated BLACK layer with
    // the sealed frame-0 synchronously — the machine boots like a machine — and the panel holds for one boot
    // beat behind .hl-boot. The wallpaper underneath is NEVER touched: the module dissolves this layer into
    // it (boot → your OS). Fail-open twice over: the module drops the layer when its canvas is live, and if
    // the module never arrives the 5s timer lifts .hl-boot and CSS fades the layer to the wallpaper lock.
    try {
      var _pl = JSON.parse(localStorage.getItem("holo.plymouth.v1") || "null");
      if (_pl && _pl.on && _wall) {
        // First boot for this theme (frames not yet sealed to κ) streams from the pack CDN — warm the
        // DNS/TLS handshake NOW so the emblem's first frames land sooner. Warm boots (sealed) skip this.
        try { if (!localStorage.getItem("holo.plymouth.frames:" + _pl.theme)) { var _pc = document.createElement("link"); _pc.rel = "preconnect"; _pc.href = "https://raw.githubusercontent.com"; _pc.crossOrigin = "anonymous"; document.head.appendChild(_pc); } } catch (e) {}
        var _base = document.createElement("div");
        _base.id = "hl-plymouth-base";
        _base.style.cssText = "position:fixed;inset:0;z-index:0;pointer-events:none;background:#000 center 46% no-repeat;transition:opacity .9s ease";
        if (_pl.firstFrame) _base.style.backgroundImage = 'url("' + _pl.firstFrame + '")';
        _wall.parentNode.insertBefore(_base, _wall.nextSibling);
        var _rm = false; try { _rm = matchMedia("(prefers-reduced-motion: reduce)").matches; } catch (e) {}
        var _ov = document.getElementById("holo-login");
        // Lean boot: hold the panel only until the emblem is alive (holo-plymouth lifts it, readiness-gated).
        // This 1.5s is ONLY the fallback for a module that never loads — never a fixed cinematic wait.
        if (_ov && !_rm) { _ov.classList.add("hl-boot"); window.__hlBootT0 = Date.now(); setTimeout(function () { try { _ov.classList.remove("hl-boot"); } catch (e) {} }, 1500); }
      }
    } catch (e) {}
  } catch (e) {}
  var fp = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"><path d="M5.5 11a6.5 6.5 0 0 1 13 0"/><path d="M8.5 11a3.5 3.5 0 0 1 7 0v2.6"/><path d="M12 11v4.4"/><path d="M8.6 14.2V16"/><path d="M15.4 15.4V18"/></svg>';
  var person = '<svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="8.4" r="4.1"/><path d="M3.8 20.4a8.2 8.2 0 0 1 16.4 0z"/></svg>';
  var avatar, name, label;
  if (op && op.label) {
    var hue = (op.hue != null ? op.hue : 210) | 0;
    var ini = op.label.trim().split(/\s+/).map(function (w) { return w[0]; }).filter(Boolean).slice(0, 2).join("").toUpperCase() || "·";
    avatar = '<div class="hl-avatar" style="background:linear-gradient(140deg,hsl(' + hue + ' 52% 46%),hsl(' + (hue + 26) + ' 52% 46%))">' + esc(ini) + '</div>';
    name = esc(op.label); label = "It’s me";
  } else {
    avatar = '<div class="hl-avatar" style="background:linear-gradient(140deg,#5b6b86,#3a455c)">' + person + '</div>';
    name = "Welcome"; label = "Sign in";
  }
  // your name IS the sign-in — one control carries who you are and the act of proving it (no heading)
  var btnText = (op && op.label) ? name : "Sign in";
  panel.innerHTML = avatar + '<div class="hl-auth"><button class="hl-bio" id="hl-baseline">' + fp + '<span>' + btnText + '</span></button><div class="status"></div></div>';
  var b = document.getElementById("hl-baseline"); if (b) b.onclick = function () { b.disabled = true; location.reload(); };
})();
</script>

<!-- LEAN BOOT — the sovereign gate + boot splash mount NOW, in PARALLEL with the heavy chat bundle below,
     so the emblem animates and the panel is ready without waiting on the messenger's code to download or
     parse. The login chain (login→signin→plymouth) is small; the preload scanner fetches it alongside the
     big bundle, and this module evaluates first, so the gate is up before the messenger even starts. The
     resolved auth promise is handed to boot() below. Fail-SOFT: a gate that can't load drops the overlay
     and boot uses its device-stable identity, never bricked. -->
<script type="module">
  try {
    const { mountLogin } = await import("./holo-messenger-login.mjs?v=signin1");
    window.__holoAuthP = mountLogin({ root: document.getElementById("root") });   // the PROMISE (resolves on sign-in), not an awaited value
  } catch (e) {
    try { const ov = document.getElementById("holo-login"); if (ov) ov.remove(); } catch {}
    window.__holoAuthP = Promise.resolve(null);
    console.warn("[login] gate unavailable, booting device-stable identity:", e);
  }
</script>

<!-- NATIVE MEDIA — the real OS media stack, loaded into the top page so the messenger rail delivers the exact
     native experience: window.HoloVinyl = the "NOW PLAYING" pill (preloaded Ben Böhmer "Begin Again"), streamed
     through the same-origin /sc/* routes the dev server now answers (holo-sc-route.mjs → yt-dlp). holo-fx.js
     drives the live equalizer; holo-vinyl lazily pulls holo-audio.js for the Hi-Fi chain. Each self-guards on the
     widgets/dock runtime, so they run standalone here. Classic defer → they set their globals before the bundle boots. -->
<script src="../../usr/lib/holo/holo-fx.js" defer></script>
<script src="../../usr/lib/holo/holo-vinyl.js" defer></script>
<script src="../../usr/lib/holo/holo-video.js" defer></script>

<script type="module">
  // ?v=N - bump on each deploy so the browser can never serve a stale cached bundle (the cause of a frozen/old build).
  import "./_vendor/ui/chat-ui.bundle.js?v=85fc48c2a927";   // → window.HoloMessengerUI
  // Opt-in: render the WhatsApp UX from STREAMING shadcn κ-components instead of the chatscope bundle.
  // Lazy — the module loads ONLY when opted in (?ui=shadcn or holo.ui.shadcn=1); the default boot never
  // parses it. Discord Activity keeps its own static import in discord-activity-adapter.mjs.
  try {
    if (new URLSearchParams(location.search).get("ui") === "shadcn" || localStorage.getItem("holo.ui.shadcn") === "1")
      await import("./messenger-shadcn-ui.mjs");
  } catch {}
  import { boot } from "./holo-messenger-app.mjs?v=ef69a04a2540";

  const root = document.getElementById("root");
  // TEE GATE + SPECULATIVE WARM PAINT, one motion. The gate already mounted (parallel module above); it
  // renders the lock + runs the biometric, while boot() starts IMMEDIATELY behind the glass, painting the
  // messenger from the local κ-snapshot during the human's look-and-tap. boot awaits the auth ONLY at its
  // identity step, so the biometric overlaps an already-live UI and loginSucceeded just unfogs onto it
  // (tap → interactive ≈ one frame). Fail-CLOSED: nothing confidential is interactable until the glass lifts.
  const authP = window.__holoAuthP || Promise.resolve(null);   // the promise the parallel gate module produced
  boot(root, authP).catch((e) => {
    document.body.innerHTML = "<pre style='color:#f88;padding:16px;white-space:pre-wrap'>boot error: " + (e && e.stack || e) + "</pre>";
  });

  // Intelligent Inbox (holo-mail) - additive, OFF by default. Enable per-operator: localStorage["holo.mail.enabled"]="1".
  import("./mail/holo-mail-attach.mjs").catch(() => {});
  // HoloChat, woven into THIS messenger — one canonical surface. Enable: localStorage["holo.chat.enabled"]="1" or ?chat=1.
  import("./holo-messenger-weave.mjs").catch(() => {});
  // Colour re-tone picker — colours only, all features intact. Gated: ?skins=1 or localStorage["holo.skins"]="1".
  import("./messenger-skin.mjs?v=8d34a1e9297f").catch(() => {});
  // Asset cache (service worker) — repeat opens serve the shell NETWORK-FREE. Escape hatch: open with ?nosw=1.
  import("./messenger-sw-register.mjs").catch(() => {});
  // Q SUMMON — tap the home orb and the canvas MORPHS into Q (View Transitions pair the orb corner→face),
  // Q greets OUT LOUD at the tap (the tap IS the autoplay gesture), the HD voice + Q's BitNet brain pre-warm
  // while home idles (window.HoloQ.warm — standalone-parity TTFT), and every Q-thread message is sealed to a
  // BLAKE3 κ chain (did:holo:blake3, hash-linked, verified on load). Additive + fail-soft.
  import("./q-summon.mjs?v=3").catch(() => {});
</script>
