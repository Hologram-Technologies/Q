<!doctype html>
<meta charset="utf-8">
<title>Holo Onion — live Snowflake rendezvous (B1c)</title>
<style>
  body { background:#0d1117; color:#c9d1d9; font:14px/1.6 ui-monospace,Menlo,monospace; margin:0; padding:32px; }
  h1 { font-size:17px; color:#a5b4fc; margin:0 0 4px; }
  .sub { color:#6e7681; margin:0 0 20px; }
  #log div { padding:2px 0; }
  .ok { color:#3fb950; } .bad { color:#f85149; } .info { color:#8b949e; }
  #state { margin-top:16px; font-weight:600; padding:10px 14px; border-radius:8px; display:inline-block; }
  .green { background:#12261a; color:#3fb950; border:1px solid #238636; }
  .red { background:#2a1416; color:#f85149; border:1px solid #da3633; }
  .warn { background:#2b2416; color:#d29922; border:1px solid #9e6a03; }
</style>
<h1>Holo Onion · live Snowflake rendezvous</h1>
<p class="sub">Reaches the real Tor Snowflake broker → volunteer proxy → opens a DataChannel. Browser-pure. This is B1c step 1: prove a live volunteer connects from a plain browser tab.</p>
<div id="log"></div>
<div id="state"></div>

<script type="module">
import { connectSnowflake } from "./holo-onion-snowflake-connect.mjs";

const logEl = document.getElementById("log");
const line = (cls, m) => { const d = document.createElement("div"); d.className = cls; d.textContent = `[${(performance.now()/1000).toFixed(1)}s] ${m}`; logEl.appendChild(d); };
const setState = (cls, m) => { const s = document.getElementById("state"); s.className = cls; s.textContent = m; };

window.__HOLO_SF__ = { stage: "start", channelOpen: false, framingReachedBridge: false, error: null };

(async () => {
  const MAX_TRIES = 4;
  for (let attempt = 1; attempt <= MAX_TRIES; attempt++) {
    line("info", `connect attempt ${attempt}/${MAX_TRIES}…`);
    let conn = null;
    try {
      conn = await connectSnowflake({ log: (m) => line("info", "  " + m), gatherTimeoutMs: 4000, openTimeoutMs: 25000 });
      line("ok", `✓ DataChannel OPEN + Token‖ClientID sent + KCP/smux started`);
      window.__HOLO_SF__ = { stage: "channel-open", channelOpen: true, framingReachedBridge: false, error: null, attempt };
      setState("warn", "channel open — probing bridge (KCP handshake)…");

      // send a small probe on the smux stream to generate KCP traffic the bridge must ACK
      conn.stream.write(new TextEncoder().encode("holo-onion-probe")).catch(() => {});

      // watch for the bridge ACKing our framing: inbound KCP packets + snd_una advancing
      const t0 = performance.now();
      while (performance.now() - t0 < 12000) {
        const s = conn.stats();
        if (s.inboundPkts > 0 && s.snd_una > 0) {
          line("ok", `✓ BRIDGE ACKed framing — inboundPkts=${s.inboundPkts} inboundBytes=${s.inboundBytes} snd_una=${s.snd_una}`);
          window.__HOLO_SF__ = { stage: "framing-reached-bridge", channelOpen: true, framingReachedBridge: true, error: null, attempt, stats: s };
          setState("green", "GREEN — encapsulation+KCP+smux reached the real Snowflake bridge. B1c framing proven in-browser. (Tor cells = Component C / arti-wasm.)");
          conn.close();
          return;
        }
        await new Promise(r => setTimeout(r, 400));
      }
      line("bad", `channel open but no bridge ACK in 12s (stats=${JSON.stringify(conn.stats())}) — proxy may not relay to the bridge; retrying`);
      conn.close();
    } catch (e) {
      line("bad", `attempt ${attempt} failed: ${e.message}`);
      window.__HOLO_SF__ = { stage: "failed", channelOpen: false, framingReachedBridge: false, error: e.message, attempt };
      try { conn && conn.close(); } catch {}
    }
  }
  setState("red", `no bridge ACK after ${MAX_TRIES} tries — see log (transient no-proxy, non-relaying proxy, or UDP/ICE blocked)`);
})();
</script>
