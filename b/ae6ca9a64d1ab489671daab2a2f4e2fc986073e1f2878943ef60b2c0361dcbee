<!-- BOOT GROUND — the ONE source of truth for the boot/login darkness. Every boot-time surface reads
     var(--boot-ground): the body pre-paint, the login --wall, the plymouth splash layer + its base, the
     signin wall, and the power veil (all with a matching literal fallback for bare surfaces without this
     token). To recolor the whole cold-open, change THIS hex and nothing else. Defined in the head so it
     resolves at the 0-ms frame, before any stylesheet or module. (The theme-color meta above is a static
     duplicate — meta tags can't read a var; keep it in sync by hand on the rare occasion this changes.) -->
<style>:root{--boot-ground:#1f1f1e}html,body{height:100%;margin:0;background:var(--boot-ground);color-scheme:dark}#root{height:100vh}</style>
<!-- PRISM PRE-PAINT (HOLO-PLAYGROUND-LIVE) — the operator's design tokens land at the 0-ms frame, the
     same discipline as --boot-ground above: read the saved token map, stamp ONE :root override before
     any stylesheet applies, so a personalized shell never flashes the base look. The durable half (the
     κ-atom stylesheet the SW materializes) covers the network layer; this covers the first frame. The
     full door (verbs, mint, prism) loads LAZILY via window.__holoPrismDoor — one import, memoized. -->
<script>
try{var _pt=JSON.parse(localStorage.getItem("holo.prism.tokens.v1")||"{}"),_pe=Object.entries(_pt).filter(function(e){return/^--holo-[\w-]{1,60}$/.test(e[0])&&/^[#a-zA-Z0-9 ,.%()\-]{1,120}$/.test(String(e[1]))});
if(_pe.length){var _ps=document.createElement("style");_ps.id="holo-prism-live";_ps.textContent=":root{"+_pe.map(function(e){return e[0]+":"+e[1]}).join(";")+"}";document.head.appendChild(_ps);}}catch(e){}
window.__holoPrismDoor=function(){var mb=new URL("../../",location.href).href;return(window.__holoPrismDoorP||(window.__holoPrismDoorP=import(new URL("usr/lib/holo/holo-prism-tokens.mjs",mb).href).then(function(m){return m.openTokenDoor({mountBase:mb})})));};
</script>
<!-- IMMERSIVE CHAT — the open conversation wears the SAME wallpaper as home. The home wallpaper is already
     painted ONCE, edge-to-edge, by the fixed .holo-backdrop canvas (the shared holo.theme.v1 wallpaper, run
     through the OS super-res lens). The thread pane used to sit on an opaque #0b141a that covered it; here we
     make the pane's surfaces translucent so that ONE backdrop shows straight through — so the chat is literally
     the same wallpaper as home, live-synced with it, zero extra fetch. Gated on .holo-backdrop.ready via :has()
     so it engages ONLY when a wallpaper is actually shown (a flat dark/light home ⇒ backdrop never turns ready
     ⇒ the chat keeps its solid default, still matching home). Scoped to the default look (html:not([data-skin]))
     so the opt-in skins / theatre keep their own immersive treatment untouched. -->
<style id="holo-chat-immersive">
  /* let the shared backdrop show through the whole right pane */
  html:not([data-skin]) .holo-wa-root:has(.holo-backdrop.ready) .cs-chat-container{background:transparent!important}
  /* one clean legibility scrim over the wallpaper (a touch darker toward the composer) — the wallpaper stays vivid */
  html:not([data-skin]) .holo-wa-root:has(.holo-backdrop.ready) .cs-message-list{
    background:linear-gradient(180deg,rgba(31,31,30,.30) 0%,rgba(31,31,30,.28) 52%,rgba(31,31,30,.50) 100%)!important;}
  /* drop the pane's own in-place photo copy + aurora glow so nothing muddies the single backdrop */
  html:not([data-skin]) .holo-wa-root:has(.holo-backdrop.ready) .cs-message-list::before,
  html:not([data-skin]) .holo-wa-root:has(.holo-backdrop.ready) .cs-message-list::after{display:none!important}
  /* header + composer become glass so the wallpaper flows unbroken top-to-bottom behind the thread */
  html:not([data-skin]) .holo-wa-root:has(.holo-backdrop.ready) .cs-conversation-header{
    background:rgba(38,38,36,.46)!important;-webkit-backdrop-filter:blur(22px) saturate(1.3);backdrop-filter:blur(22px) saturate(1.3);
    border-bottom:1px solid rgba(255,255,255,.07)!important;}
  html:not([data-skin]) .holo-wa-root:has(.holo-backdrop.ready) .cs-message-input{
    background:rgba(38,38,36,.42)!important;-webkit-backdrop-filter:blur(22px) saturate(1.2);backdrop-filter:blur(22px) saturate(1.2);
    border-top:1px solid rgba(255,255,255,.07)!important;}
  html:not([data-skin]) .holo-wa-root:has(.holo-backdrop.ready) .cs-input-toolbox{background:transparent!important}
</style>
<script>
/* preload the shipped default wallpaper ONLY when no custom pick exists — with a custom wallpaper the
   default is never painted and a static preload is dead weight (Chrome: "preloaded but not used"). */
try { var _pt = JSON.parse(localStorage.getItem("holo.theme.v1") || "{}") || {};
  if (!_pt.wallpaper && !localStorage.getItem("holo-messenger/wallpaper-src")) {
    var _pl = document.createElement("link"); _pl.rel = "preload"; _pl.as = "image";
    _pl.href = "./_vendor/wallpaper-default.jpg"; _pl.fetchPriority = "high"; document.head.appendChild(_pl);
  } } catch (e) {}
</script>
