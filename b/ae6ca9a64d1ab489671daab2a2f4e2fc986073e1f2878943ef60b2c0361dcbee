<!-- ── TEE SIGN-IN GATE (holo-messenger-login.mjs) ─────────────────────────────────────────────────
     A full-bleed lock overlay above #root, IDENTICAL to the OS native CEF greeter — the messenger does
     not paint until a sovereign identity is established (Windows Hello / Touch ID via holo-webauthn →
     holo-login κ). This is the never-blank baseline first-paint; the module ENHANCES it (real biometric
     wiring). φ-proportioned, black-on-teal, glass-unfog on success — the same vocabulary as holo://login. -->
<style>
  #holo-login{position:fixed;inset:0;z-index:2147483000;color:var(--ink);
    font-family:"Segoe UI",system-ui,-apple-system,"Oxygen",sans-serif;--phi:1.618;
    --u:clamp(17px,1.8vmin,20px);--g1:calc(var(--u)*1.618);--g2:calc(var(--u)*2.618);
    --avatar:clamp(96px,calc(var(--u)*6.854),128px);--field:min(86vw,calc(var(--avatar)*2.618));
    --accent:#7defc9;--accent-2:#34d3a6;
    /* ONE appearance token set — every element reads these; [data-appearance] flips them.
       immersive (default) = the home wallpaper behind soft-shadowed ink · dark/light = flat, shadowless, high contrast */
    --ink:#f4f7fc;--ink-dim:rgba(231,237,250,.82);--status:#c4f3e2;
    --shadow:0 2px 18px rgba(0,0,0,.45);--wall:var(--boot-ground,#1f1f1e);
    --glass:rgba(10,14,20,.42);--glass-border:rgba(255,255,255,.14);--glass-ink:rgba(231,237,250,.8);
    --sheet:rgba(8,12,18,.94);--muted:#8b949e;--link:#58a6ff;--field-bg:rgba(255,255,255,.09);--field-border:rgba(255,255,255,.22);}
  #holo-login[data-appearance="dark"]{--shadow:none;}
  #holo-login[data-appearance="light"]{--ink:#0b1220;--ink-dim:rgba(11,18,32,.74);--status:#0e6f5c;
    --shadow:none;--wall:#eef1f6;
    --glass:rgba(255,255,255,.66);--glass-border:rgba(11,18,32,.18);--glass-ink:rgba(11,18,32,.8);
    --sheet:rgba(250,252,255,.97);--muted:#5a6572;--link:#0969da;--field-bg:rgba(11,18,32,.06);--field-border:rgba(11,18,32,.22);}
  #holo-login *{box-sizing:border-box;}
  #holo-login .hl-wall{position:fixed;inset:0;z-index:0;background:var(--wall) center/cover no-repeat;}
  /* the wallpaper shows EXACTLY as the home screen wears it — no blur, no scrim. The layer stays only as
     the unfog animation target; text/buttons carry their own shadows for legibility. */
  #holo-login .hl-frost{position:fixed;inset:0;z-index:1;background:transparent;pointer-events:none;}
  /* THE BRAND AT FRAME ZERO (HOLO-BOOT-CEREMONY B1): H mark + wordmark, bottom-centre golden band, painted
     synchronously with the black — inline bytes, zero fetches, never blinks across the whole ceremony. */
  #holo-login .hl-brand{position:fixed;left:50%;transform:translateX(-50%);bottom:max(26px,env(safe-area-inset-bottom));z-index:3;
    pointer-events:none;display:inline-flex;align-items:center;gap:clamp(11px,1.4vw,16px);color:var(--ink);}
  #holo-login .hl-brand svg{width:clamp(36px,4.2vw,44px);height:clamp(36px,4.2vw,44px);flex:0 0 auto;filter:drop-shadow(var(--shadow));shape-rendering:geometricPrecision;}
  #holo-login .hl-brand b{font:600 clamp(24px,3.6vw,36px)/1 "Bahnschrift","DIN Alternate","DIN Next","Roboto Condensed","Segoe UI",system-ui,sans-serif;letter-spacing:.26em;text-transform:uppercase;padding-left:.26em;color:var(--ink-dim);text-shadow:var(--shadow);-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;text-rendering:geometricPrecision;}
  /* GOLDEN COMPOSITION: the identity + actions sit on the LOWER golden line (61.8vh); the hero emblem grows
     upward to fill the upper golden-major section, its centre landing on the UPPER golden line (38.2vh) — both
     golden lines expressed at once. All gaps are already φ-scaled (--g1/--g2), so the column derives from φ. */
  #holo-login .hl-lock{position:fixed;inset:0;z-index:2;display:grid;justify-items:center;align-items:start;
    padding:calc(61.8vh - var(--avatar)/2) var(--g2) var(--g2);
    padding-top:calc(61.8dvh - var(--avatar)/2);}   /* dvh: the golden line holds while mobile URL bars collapse */
  /* Short screens AND phones (narrow → the square emblem is width-bound, can't fill the tall golden major)
     lift the identity so the actions don't sit too low and the top isn't left empty. */
  @media (max-height:620px),(max-width:500px){#holo-login .hl-lock{padding-top:calc(56vh - var(--avatar)/2);padding-top:calc(56dvh - var(--avatar)/2);}}
  #holo-login .hl-panel{display:flex;flex-direction:column;align-items:center;text-align:center;width:var(--field);max-width:92vw;}
  #holo-login .hl-avatar{width:var(--avatar);height:var(--avatar);border-radius:50%;display:grid;place-items:center;color:#fff;
    font-size:calc(var(--avatar)*.37);font-weight:600;letter-spacing:.02em;user-select:none;
    box-shadow:0 .5em 1.5em rgba(0,0,0,.35),inset 0 0 0 1.5px rgba(255,255,255,.38);}
  #holo-login .hl-avatar svg{width:62%;height:62%;opacity:.92;}
  #holo-login .hl-name{margin:var(--g1) 0 0;font-size:calc(var(--u)*1.12);font-weight:600;letter-spacing:.01em;line-height:1.15;text-shadow:var(--shadow);}
  #holo-login .hl-auth{margin-top:var(--u);display:flex;flex-direction:column;align-items:center;gap:var(--u);width:100%;}
  /* THE ONE IDENTITY CONTROL — your name IS the sign-in: fingerprint + name, one sharp object. While the
     enclave checks you it SCANS (pure CSS on :disabled — a light sweep, the biometric moment made visible). */
  #holo-login .hl-bio{position:relative;overflow:hidden;width:100%;min-height:max(var(--g2),52px);border:0;border-radius:calc(var(--u)*.7);cursor:pointer;
    display:inline-flex;align-items:center;justify-content:center;gap:calc(var(--u)*.55);font-size:var(--u);font-weight:600;color:#06140f;
    background:linear-gradient(180deg,#38d9ab,#2cc79b);box-shadow:inset 0 1px 0 rgba(255,255,255,.22),0 1px 2px rgba(0,0,0,.3),0 8px 24px rgba(0,0,0,.22);font-family:inherit;
    transition:transform .12s,box-shadow .18s,filter .18s;
    /* ONE MATERIAL, RESTRAINED ACCENT (Claude-desktop caliber): the declarations below SUPERSEDE the first
       two lines of this rule (kept byte-verbatim above — the ship anti-revert gate pins them as live
       probes): house 10px radius, deep ink, calm 180deg fill, NEUTRAL shadows — the green is a jewel,
       not a wall. MIRROR of holo-signin.mjs HL_CSS — same computed values, or the module swap flashes. */
    /* OBSIDIAN IGNITE (Pure): the two lines above are pinned live probes (green jewel); THESE supersede them —
       the key is obsidian glass at rest, hairline-bordered, ink label + a mint fingerprint. Sovereign when
       idle, it ignites mint only while the enclave verifies (the beam rule below). Fixed dark ground so the
       key reads the same on any wallpaper and in light appearance. */
    border-radius:12px;letter-spacing:.01em;color:#eef2f8;
    background:linear-gradient(180deg,rgba(28,30,28,.94),rgba(12,13,12,.96));border:1px solid rgba(255,255,255,.16);
    box-shadow:inset 0 1px 0 rgba(255,255,255,.06),0 12px 34px rgba(0,0,0,.5);}
  #holo-login .hl-bio:hover{transform:translateY(-1px);border-color:rgba(125,239,201,.45);filter:none;
    box-shadow:inset 0 1px 0 rgba(255,255,255,.08),0 16px 40px rgba(0,0,0,.55),0 0 0 1px rgba(52,211,166,.1);}
  #holo-login .hl-bio:active{transform:translateY(0) scale(.99);}
  #holo-login .hl-bio:disabled{cursor:progress;border-color:rgba(125,239,201,.55);}
  #holo-login .hl-bio:disabled span{color:var(--accent);}                 /* label warms to mint on verify */
  #holo-login .hl-bio svg:not(.hl-beam){width:1.3em;height:1.3em;flex:0 0 auto;color:var(--accent);}
  /* OBSIDIAN IGNITE beam — a single mint comet winds the whole rim once per loop while the enclave checks.
     The module sizes this SVG rect to the key's exact px, so the comet is even on a wide button. */
  #holo-login .hl-bio .hl-beam{position:absolute;inset:0;width:100%;height:100%;pointer-events:none;opacity:0;transition:opacity .2s;}
  #holo-login .hl-bio .hl-beam rect{fill:none;stroke:var(--accent);stroke-width:1.6;stroke-dasharray:15 85;stroke-linecap:round;filter:drop-shadow(0 0 5px rgba(52,211,166,.7));}
  #holo-login .hl-bio:disabled .hl-beam{opacity:1;}
  #holo-login .hl-bio:disabled .hl-beam rect{animation:hl-beam 1.3s linear infinite;}
  @keyframes hl-beam{from{stroke-dashoffset:100;}to{stroke-dashoffset:0;}}
  /* ENCLAVE ASSURANCE LINE — names who guards the key (the security read), just under it. */
  #holo-login .hl-enclave{margin-top:calc(var(--u)*-.5);display:flex;align-items:center;justify-content:center;gap:calc(var(--u)*.35);
    font-size:calc(var(--u)*.72);color:var(--ink-dim);opacity:.72;text-shadow:var(--shadow);}
  /* SUPERSEDES the pinned probe above → enclave line matches the name + guest size (one type size, larger). */
  #holo-login .hl-enclave{margin-top:calc(var(--u)*-.35);gap:calc(var(--u)*.42);font-size:var(--u);font-weight:450;opacity:.66;}
  #holo-login .hl-enclave svg{width:1em;height:1em;color:var(--accent);opacity:.9;flex:0 0 auto;}
  /* SLIDE TO ENTER — touch devices only (the module renders this instead of the tap key on coarse pointers).
     A deliberate drag is intent that can't misfire; the biometric fires on release. Same obsidian/mint language. */
  #holo-login .hl-slide{position:relative;width:100%;min-height:max(var(--g2),56px);border-radius:12px;user-select:none;touch-action:none;overflow:hidden;
    background:linear-gradient(180deg,rgba(28,30,28,.94),rgba(12,13,12,.96));border:1px solid rgba(255,255,255,.16);box-shadow:inset 0 1px 3px rgba(0,0,0,.6);}
  #holo-login .hl-slide .hl-fill{position:absolute;top:0;bottom:0;left:0;width:0;border-radius:12px;background:linear-gradient(90deg,rgba(52,211,166,.34),rgba(52,211,166,.03));}
  #holo-login .hl-slide .hl-track-lbl{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;gap:calc(var(--u)*.45);pointer-events:none;color:var(--ink-dim);font-size:var(--u);font-weight:500;letter-spacing:.01em;text-shadow:var(--shadow);}
  #holo-login .hl-slide .hl-knob{position:absolute;top:4px;bottom:4px;left:4px;aspect-ratio:1;border-radius:9px;cursor:grab;display:grid;place-items:center;color:#062019;
    background:linear-gradient(180deg,#3ce0b0,#28c096);box-shadow:0 4px 12px rgba(0,0,0,.45),inset 0 1px 0 rgba(255,255,255,.42);touch-action:none;}
  #holo-login .hl-slide .hl-knob:active{cursor:grabbing;}
  #holo-login .hl-slide .hl-knob svg{width:1.3em;height:1.3em;color:#062019;}
  #holo-login .hl-slide.armed{border-color:rgba(125,239,201,.5);}
  #holo-login .hl-slide.done .hl-fill{width:100%!important;background:linear-gradient(90deg,#34d3a6,#7defc9);}
  #holo-login .hl-alt{background:none;border:0;color:var(--ink-dim);opacity:.66;margin-top:calc(var(--u)*.3);font-size:calc(var(--u)*.82);font-weight:500;font-family:inherit;cursor:pointer;
    padding:calc(var(--u)*.3) calc(var(--u)*.55);border-radius:calc(var(--u)*.4);display:inline-flex;align-items:center;gap:calc(var(--u)*.4);transition:color .15s,opacity .15s;min-height:44px;}
  #holo-login .hl-alt:hover{color:var(--ink);opacity:1;}
  #holo-login .hl-alt svg{width:1.05em;height:1.05em;}
  /* "More options" is subordinate to the two core actions — quieter (same size, ONE type size everywhere). */
  #holo-login .hl-more{opacity:.72;}
  #holo-login .hl-more:hover{opacity:1;}
  #holo-login .hl-opts{display:flex;gap:calc(var(--u)*.3);justify-content:center;flex-wrap:wrap;}
  #holo-login .hl-opts[hidden]{display:none;}
  #holo-login .status{min-height:calc(var(--u)*1.5);font-size:var(--u);color:var(--status);display:flex;align-items:center;justify-content:center;gap:calc(var(--u)*.5);text-shadow:var(--shadow);}
  #holo-login .status.err{color:#ffc0c0;}
  #holo-login .spin{width:1em;height:1em;border-radius:50%;border:2px solid rgba(125,239,201,.28);border-top-color:var(--accent);animation:hl-spin .7s linear infinite;flex:0 0 auto;}
  @keyframes hl-spin{to{transform:rotate(360deg);}}
  #holo-login .hl-panel{animation:hl-rise .7s cubic-bezier(.4,0,.2,1) .05s both;}
  @keyframes hl-rise{from{opacity:0;transform:translateY(10px) scale(.99);filter:blur(2px);}to{opacity:1;transform:none;filter:none;}}
  /* GLASS UNFOG on success — frost dissolves + panel lifts; boot() paints the messenger beneath, no seam. */
  #holo-login.unfog .hl-frost{animation:hl-defog .72s cubic-bezier(.4,0,.2,1) forwards;}
  #holo-login.unfog .hl-panel{animation:hl-lift .68s cubic-bezier(.4,0,.2,1) forwards;pointer-events:none;}
  @keyframes hl-defog{to{opacity:0;}}
  @keyframes hl-lift{to{opacity:0;transform:translateY(-10px) scale(1.03);}}
  @media (prefers-reduced-motion:reduce){#holo-login .hl-panel,#holo-login .spin{animation:none;}#holo-login.unfog .hl-frost,#holo-login.unfog .hl-panel{animation:hl-defog .3s ease forwards;}}
  /* PLYMOUTH BOOT BEAT — while .hl-boot, the machine is booting: pure splash, panel held. holo-plymouth.mjs
     lifts it (or the baseline's own 5s timer does — never a lock-out). Must live HERE for the 0-ms frame.
     When the beat lifts, the baseline splash layer dissolves to the wallpaper by CSS alone — so even a
